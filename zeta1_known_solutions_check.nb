        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", " ", "-", " ", 
           RowBox[{"I", " ", "lam"}]}], ")"}], " ", 
         RowBox[{"LaguerreL", "[", 
          RowBox[{
           RowBox[{"I", " ", 
            RowBox[{"lam", "/", "2"}]}], ",", " ", 
           RowBox[{
            RowBox[{"-", "2"}], " ", "I", " ", "x"}]}], "]"}]}], " ", "+", 
        "\n", "      ", 
        RowBox[{"I", " ", "lam", " ", 
         RowBox[{"Hypergeometric1F1", "[", 
          RowBox[{
           RowBox[{"1", " ", "-", " ", 
            RowBox[{"I", " ", 
             RowBox[{"lam", "/", "2"}]}]}], ",", " ", "2", ",", " ", 
           RowBox[{
            RowBox[{"-", "2"}], " ", "I", " ", "x"}]}], "]"}]}]}], ")"}]}]}], 
    ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"zeta12", " ", "=", "\n", "   ", 
     RowBox[{
      RowBox[{"f0", "[", 
       RowBox[{"-", "lam"}], "]"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
