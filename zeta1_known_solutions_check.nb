             RowBox[{"lam", "/", "2"}]}]}], ",", " ", "2", ",", " ", 
           RowBox[{
            RowBox[{"-", "2"}], " ", "I", " ", "x"}]}], "]"}]}]}], ")"}]}]}], 
    ";"}], "\n", "\n", 
