Notebook[{

Cell[CellGroupData[{
Cell["Check of the two known solutions for zeta1(x)", "Title",ExpressionUUID->"172b9db0-14c5-4a87-9423-6ee611a2d882"],

Cell["\<\
This notebook checks the derivation of the two bounded/Laplace-transform \
solutions zeta11 and zeta12. It is written defensively: symbolic steps are \
kept separate, and the expensive checks are wrapped with TimeConstrained so \
an unevaluated identity does not stop the notebook.\
\>", "Text",ExpressionUUID->"7bd023a1-c023-48b9-b705-949a862e56a5"],

Cell[CellGroupData[{

Cell["0. Setup", "Section",ExpressionUUID->"e4795aa0-efa7-49d5-a2e1-4981598b14d2"],

Cell[BoxData[
 RowBox[{"\n", 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"$Assumptions", " ", "=", " ", 
     RowBox[{
      RowBox[{"Element", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"x", ",", " ", "s", ",", " ", "lam"}], "}"}], ",", " ", 
        "Reals"}], "]"}], " ", "&&", " ", 
      RowBox[{"x", " ", ">", " ", "0"}], " ", "&&", " ", 
      RowBox[{"s", " ", ">", " ", "0"}], " ", "&&", " ", 
      RowBox[{"lam", " ", ">", " ", "0"}]}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"odeX", "[", "y_", "]"}], " ", ":=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"x", "^", "2"}], " ", 
       RowBox[{"D", "[", 
        RowBox[{"y", ",", " ", 
         RowBox[{"{", 
          RowBox[{"x", ",", " ", "4"}], "}"}]}], "]"}]}], " ", "+", " ", 
      RowBox[{"4", " ", "x", " ", 
       RowBox[{"(", 
        RowBox[{"1", " ", "+", " ", 
         RowBox[{"I", " ", "x"}]}], ")"}], " ", 
       RowBox[{"D", "[", 
        RowBox[{"y", ",", " ", 
         RowBox[{"{", 
          RowBox[{"x", ",", " ", "3"}], "}"}]}], "]"}]}], " ", "+", "\n", 
      "   ", 
      RowBox[{"2", " ", "x", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"5", " ", "I"}], " ", "-", " ", 
         RowBox[{"2", " ", "x"}]}], ")"}], " ", 
       RowBox[{"D", "[", 
        RowBox[{"y", ",", " ", 
         RowBox[{"{", 
          RowBox[{"x", ",", " ", "2"}], "}"}]}], "]"}]}], " ", "-", " ", 
      RowBox[{"2", " ", 
       RowBox[{"(", 
        RowBox[{"I", " ", "+", " ", 
         RowBox[{"2", " ", "x"}]}], ")"}], " ", 
       RowBox[{"D", "[", 
        RowBox[{"y", ",", " ", "x"}], "]"}]}], " ", "-", " ", 
      RowBox[{
       RowBox[{"lam", "^", "2"}], " ", "y"}]}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"coefA", "[", "s_", "]"}], " ", ":=", " ", 
     RowBox[{
      RowBox[{"s", "^", "2"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"s", "^", "2"}], " ", "+", " ", 
        RowBox[{"4", " ", "I", " ", "s"}], " ", "-", " ", "4"}], ")"}]}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"coefB", "[", "s_", "]"}], " ", ":=", " ", 
     RowBox[{"2", " ", "s", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", " ", 
         RowBox[{"s", "^", "2"}]}], " ", "+", " ", 
        RowBox[{"7", " ", "I", " ", "s"}], " ", "-", " ", "6"}], ")"}]}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"coefC", "[", "s_", "]"}], " ", ":=", " ", 
     RowBox[{"-", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"lam", "^", "2"}], " ", "+", " ", "4", " ", "-", " ", 
        RowBox[{"2", " ", "I", " ", "s"}]}], ")"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"opS", "[", "y_", "]"}], " ", ":=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"coefA", "[", "s", "]"}], " ", 
       RowBox[{"D", "[", 
        RowBox[{"y", ",", " ", 
         RowBox[{"{", 
          RowBox[{"s", ",", " ", "2"}], "}"}]}], "]"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"coefB", "[", "s", "]"}], " ", 
       RowBox[{"D", "[", 
        RowBox[{"y", ",", " ", "s"}], "]"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"coefC", "[", "s", "]"}], " ", "y"}]}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"safeSimplify", "[", 
      RowBox[{"expr_", ",", " ", 
       RowBox[{"sec_", ":", " ", "30"}]}], "]"}], " ", ":=", " ", 
     RowBox[{"TimeConstrained", "[", "\n", "   ", 
      RowBox[{
       RowBox[{"FullSimplify", "[", 
        RowBox[{
         RowBox[{"PowerExpand", "[", 
          RowBox[{"FunctionExpand", "[", "expr", "]"}], "]"}], ",", " ", 
         RowBox[{"Assumptions", " ", "->", " ", "$Assumptions"}]}], "]"}], ",",
        "\n", "   ", "sec", ",", "\n", "   ", "expr"}], "\n", "]"}]}], ";"}], 
   "\n"}]}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"ba0c0705-bc97-4b42-8733-14994ba316ab"]
}, Open  ]],

Cell[CellGroupData[{

Cell["1. Boundary relation at x = 0", "Section",ExpressionUUID->"0fb45a0d-ea1f-4557-b3e6-8cab458c7bb9"],

Cell["\<\
Insert a generic Taylor jet. The constant term of the ODE must vanish if \
zeta1 and its derivatives are finite at x=0+.\
\>", "Text",ExpressionUUID->"611041dd-dc0d-499e-b513-0ca460b32586"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\n", 
  RowBox[{
   RowBox[{
    RowBox[{"jet", " ", "=", " ", 
     RowBox[{"z0", " ", "+", " ", 
      RowBox[{"z1", " ", "x"}], " ", "+", " ", 
      RowBox[{"z2", " ", 
       RowBox[{
        RowBox[{"x", "^", "2"}], "/", "2"}]}], " ", "+", " ", 
      RowBox[{"z3", " ", 
       RowBox[{
        RowBox[{"x", "^", "3"}], "/", "6"}]}], " ", "+", " ", 
      RowBox[{"z4", " ", 
       RowBox[{
        RowBox[{"x", "^", "4"}], "/", "24"}]}]}]}], ";"}], "\n", 
   RowBox[{"constantTermAt0", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"Series", "[", 
       RowBox[{
        RowBox[{"odeX", "[", "jet", "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"x", ",", " ", "0", ",", " ", "0"}], "}"}]}], "]"}], " ", "//",
       " ", "Normal"}], " ", "//", " ", "FullSimplify"}]}], "\n", 
   RowBox[{"boundaryRelation", " ", "=", " ", 
    RowBox[{
     RowBox[{"Solve", "[", 
      RowBox[{
       RowBox[{"constantTermAt0", " ", "==", " ", "0"}], ",", " ", "z0"}], 
      "]"}], " ", "//", " ", "FullSimplify"}]}], "\n", 
   RowBox[{"boundaryCheck", " ", "=", " ", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{"constantTermAt0", " ", "/.", " ", 
      RowBox[{"z0", " ", "->", " ", 
       RowBox[{
        RowBox[{"-", "2"}], " ", "I", " ", 
        RowBox[{"z1", "/", 
         RowBox[{"lam", "^", "2"}]}]}]}]}], "]"}]}], "\n"}]}]], "Input",
 CellLabel->"In[9]:=",ExpressionUUID->"408d326a-5bb4-4bc4-90cf-58699df8b806"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"-", 
    SuperscriptBox["lam", "2"]}], " ", "z0"}], "-", 
  RowBox[{"2", " ", "\[ImaginaryI]", " ", "z1"}]}]], "Output",
 CellChangeTimes->{3.988703971599533*^9},
 CellLabel->"Out[10]=",ExpressionUUID->"4c2fd460-5265-4a9a-bafd-bfceedf57ace"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{"z0", "\[Rule]", 
    RowBox[{"-", 
     FractionBox[
      RowBox[{"2", " ", "\[ImaginaryI]", " ", "z1"}], 
      SuperscriptBox["lam", "2"]]}]}], "}"}], "}"}]], "Output",
 CellChangeTimes->{3.988703971610201*^9},
 CellLabel->"Out[11]=",ExpressionUUID->"397440a3-bb88-443f-8af1-dfb910bd2ee2"],

Cell[BoxData["0"], "Output",
 CellChangeTimes->{3.9887039716110897`*^9},
 CellLabel->"Out[12]=",ExpressionUUID->"8daba6e5-2fe3-4f45-a062-0b832f92dcd6"]
}, Open  ]],

Cell["\<\
Expected: constantTermAt0 = -lam^2 z0 - 2 I z1, so -2 I zeta1'(0) = lam^2 \
zeta1(0).\
\>", "Text",ExpressionUUID->"ae2d0b5e-79a8-4d77-a6fc-e6f145586d4a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["2. Derive the Laplace-transformed equation", "Section",ExpressionUUID->"6ba08e7b-de6b-40cb-b25c-08f6946fbb28"],

Cell["\<\
Let LL[s] be LaplaceTransform[zeta1[x],x,s]. The rules used are L[x f] = -d_s \
L[f] and L[x^2 f] = d_s^2 L[f].\
\>", "Text",ExpressionUUID->"21de601c-381e-464f-b8e8-32bf1ecc30c1"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\n", 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", 
     RowBox[{"LL", ",", " ", "ic"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"ic", "[", "0", "]"}], " ", "=", " ", "z0"}], ";", " ", 
    RowBox[{
     RowBox[{"ic", "[", "1", "]"}], " ", "=", " ", "z1"}], ";", " ", 
    RowBox[{
     RowBox[{"ic", "[", "2", "]"}], " ", "=", " ", "z2"}], ";", " ", 
    RowBox[{
     RowBox[{"ic", "[", "3", "]"}], " ", "=", " ", "z3"}], ";"}], "\n", "\n", 
   
   RowBox[{
    RowBox[{
     RowBox[{"lapD", "[", "n_Integer", "]"}], " ", ":=", " ", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"n", " ", "==", " ", "0"}], ",", " ", 
       RowBox[{"LL", "[", "s", "]"}], ",", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"s", "^", "n"}], " ", 
         RowBox[{"LL", "[", "s", "]"}]}], " ", "-", " ", 
        RowBox[{"Sum", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"s", "^", 
            RowBox[{"(", 
             RowBox[{"n", " ", "-", " ", "1", " ", "-", " ", "j"}], ")"}]}], " ", 
           RowBox[{"ic", "[", "j", "]"}]}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"j", ",", " ", "0", ",", " ", 
            RowBox[{"n", " ", "-", " ", "1"}]}], "}"}]}], "]"}]}]}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"lapX", "[", "expr_", "]"}], " ", ":=", " ", 
     RowBox[{"-", 
      RowBox[{"D", "[", 
       RowBox[{"expr", ",", " ", "s"}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"lapX2", "[", "expr_", "]"}], " ", ":=", " ", 
     RowBox[{"D", "[", 
      RowBox[{"expr", ",", " ", 
       RowBox[{"{", 
        RowBox[{"s", ",", " ", "2"}], "}"}]}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"lapEquationRaw", " ", "=", "\n", "   ", 
     RowBox[{
      RowBox[{"lapX2", "[", 
       RowBox[{"lapD", "[", "4", "]"}], "]"}], " ", "+", "\n", "   ", 
      RowBox[{"4", " ", 
       RowBox[{"lapX", "[", 
        RowBox[{"lapD", "[", "3", "]"}], "]"}]}], " ", "+", " ", 
      RowBox[{"4", " ", "I", " ", 
       RowBox[{"lapX2", "[", 
        RowBox[{"lapD", "[", "3", "]"}], "]"}]}], " ", "+", "\n", "   ", 
      RowBox[{"10", " ", "I", " ", 
       RowBox[{"lapX", "[", 
        RowBox[{"lapD", "[", "2", "]"}], "]"}]}], " ", "-", " ", 
      RowBox[{"4", " ", 
       RowBox[{"lapX2", "[", 
        RowBox[{"lapD", "[", "2", "]"}], "]"}]}], " ", "-", "\n", "   ", 
      RowBox[{"2", " ", "I", " ", 
       RowBox[{"lapD", "[", "1", "]"}]}], " ", "-", " ", 
      RowBox[{"4", " ", 
       RowBox[{"lapX", "[", 
        RowBox[{"lapD", "[", "1", "]"}], "]"}]}], " ", "-", "\n", "   ", 
      RowBox[{
       RowBox[{"lam", "^", "2"}], " ", 
       RowBox[{"lapD", "[", "0", "]"}]}]}]}], ";"}], "\n", "\n", 
   RowBox[{"lapEquation", " ", "=", " ", 
    RowBox[{"Collect", "[", 
     RowBox[{
      RowBox[{"Expand", "[", "lapEquationRaw", "]"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"LL", "''"}], "[", "s", "]"}], ",", " ", 
        RowBox[{
         RowBox[{"LL", "'"}], "[", "s", "]"}], ",", " ", 
        RowBox[{"LL", "[", "s", "]"}], ",", " ", "z0", ",", " ", "z1"}], 
       "}"}], ",", " ", "FullSimplify"}], "]"}]}], "\n", "\n", 
   RowBox[{
    RowBox[{"expectedLapEquation", " ", "=", "\n", "   ", 
     RowBox[{
      RowBox[{
       RowBox[{"s", "^", "2"}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"s", "^", "2"}], " ", "+", " ", 
         RowBox[{"4", " ", "I", " ", "s"}], " ", "-", " ", "4"}], ")"}], " ", 
       
       RowBox[{
        RowBox[{"LL", "''"}], "[", "s", "]"}]}], " ", "+", "\n", "   ", 
      RowBox[{"2", " ", "s", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "6"}], " ", "+", " ", 
         RowBox[{"7", " ", "I", " ", "s"}], " ", "+", " ", 
         RowBox[{"2", " ", 
          RowBox[{"s", "^", "2"}]}]}], ")"}], " ", 
       RowBox[{
        RowBox[{"LL", "'"}], "[", "s", "]"}]}], " ", "+", "\n", "   ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"lam", "^", "2"}]}], " ", "+", " ", 
         RowBox[{"2", " ", "I", " ", "s"}], " ", "-", " ", "4"}], ")"}], " ", 
       
       RowBox[{"LL", "[", "s", "]"}]}], " ", "+", "\n", "   ", 
      RowBox[{"2", " ", 
       RowBox[{"(", 
        RowBox[{"z1", " ", "+", " ", 
         RowBox[{"2", " ", "I", " ", "z0"}], " ", "+", " ", 
         RowBox[{"z0", " ", "s"}]}], ")"}]}]}]}], ";"}], "\n", "\n", 
   RowBox[{"lapEquationCheck", " ", "=", " ", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{"lapEquation", " ", "-", " ", "expectedLapEquation"}], "]"}]}], 
   "\n"}]}]], "Input",
 CellLabel->"In[13]:=",ExpressionUUID->"069e2cd0-96e8-4870-be51-504fc278066b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"2", " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"2", " ", "\[ImaginaryI]"}], "+", "s"}], ")"}], " ", "z0"}], "+", 
  RowBox[{"2", " ", "z1"}], "+", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "4"}], "-", 
     SuperscriptBox["lam", "2"], "+", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "s"}]}], ")"}], " ", 
   RowBox[{"LL", "[", "s", "]"}]}], "+", 
  RowBox[{"2", " ", "s", " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"2", " ", "\[ImaginaryI]"}], "+", "s"}], ")"}], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"3", " ", "\[ImaginaryI]"}], "+", 
     RowBox[{"2", " ", "s"}]}], ")"}], " ", 
   RowBox[{
    SuperscriptBox["LL", "\[Prime]",
     MultilineFunction->None], "[", "s", "]"}]}], "+", 
  RowBox[{
   SuperscriptBox["s", "2"], " ", 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", "\[ImaginaryI]"}], "+", "s"}], ")"}], "2"], " ", 
   RowBox[{
    SuperscriptBox["LL", "\[Prime]\[Prime]",
     MultilineFunction->None], "[", "s", "]"}]}]}]], "Output",
 CellChangeTimes->{3.988703974278092*^9},
 CellLabel->"Out[19]=",ExpressionUUID->"7e928e1e-50e4-482f-a8ad-cbeebc8d672a"],

Cell[BoxData["0"], "Output",
 CellChangeTimes->{3.9887039742791777`*^9},
 CellLabel->"Out[21]=",ExpressionUUID->"015bf225-810b-4c88-af90-e0f95708d7d5"]
}, Open  ]],

Cell["\<\
Expected: lapEquationCheck = 0. This confirms the transformed equation in the \
PDF.\
\>", "Text",ExpressionUUID->"4e3a274a-5a8d-4175-9945-07a1fa65666a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["3. Apply the boundary relation and shift the transform", "Section",ExpressionUUID->"22bc5636-f44a-43d2-9b31-b3430a853e83"],

Cell["\<\
Using z0 = -2 I z1/lam^2, the equation has a constant particular solution. \
Shifting LL[s] = LLt[s] + 2 z1/lam^2 leaves a homogeneous equation for LLt.\
\>", "Text",ExpressionUUID->"eab847c2-c3b9-4854-b864-cd875ed50e48"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\n", 
  RowBox[{
   RowBox[{"boundedLapEquation", " ", "=", " ", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{"expectedLapEquation", " ", "/.", " ", 
      RowBox[{"z0", " ", "->", " ", 
       RowBox[{
        RowBox[{"-", "2"}], " ", "I", " ", 
        RowBox[{"z1", "/", 
         RowBox[{"lam", "^", "2"}]}]}]}]}], "]"}]}], "\n", "\n", 
   RowBox[{
    RowBox[{"expectedBoundedLapEquation", " ", "=", "\n", "   ", 
     RowBox[{
      RowBox[{
       RowBox[{"coefA", "[", "s", "]"}], " ", 
       RowBox[{
        RowBox[{"LL", "''"}], "[", "s", "]"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"coefB", "[", "s", "]"}], " ", 
       RowBox[{
        RowBox[{"LL", "'"}], "[", "s", "]"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"coefC", "[", "s", "]"}], " ", 
       RowBox[{"LL", "[", "s", "]"}]}], " ", "+", "\n", "   ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"2", " ", 
         RowBox[{"z1", "/", 
          RowBox[{"lam", "^", "2"}]}]}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"lam", "^", "2"}], " ", "+", " ", "4", " ", "-", " ", 
         RowBox[{"2", " ", "I", " ", "s"}]}], ")"}]}]}]}], ";"}], "\n", "\n", 
   
   RowBox[{"boundedEquationCheck", " ", "=", " ", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{
     "boundedLapEquation", " ", "-", " ", "expectedBoundedLapEquation"}], 
     "]"}]}], "\n", "\n", 
   RowBox[{
    RowBox[{"shiftRules", " ", "=", " ", 
     RowBox[{"{", "\n", "   ", 
      RowBox[{
       RowBox[{
        RowBox[{"LL", "[", "s", "]"}], " ", "->", " ", 
        RowBox[{
         RowBox[{"LLt", "[", "s", "]"}], " ", "+", " ", 
         RowBox[{"2", " ", 
          RowBox[{"z1", "/", 
           RowBox[{"lam", "^", "2"}]}]}]}]}], ",", "\n", "   ", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Derivative", "[", "1", "]"}], "[", "LL", "]"}], "[", "s", 
         "]"}], " ", "->", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"Derivative", "[", "1", "]"}], "[", "LLt", "]"}], "[", "s", 
         "]"}]}], ",", "\n", "   ", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Derivative", "[", "2", "]"}], "[", "LL", "]"}], "[", "s", 
         "]"}], " ", "->", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"Derivative", "[", "2", "]"}], "[", "LLt", "]"}], "[", "s", 
         "]"}]}]}], "\n", "}"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"shiftedEquation", " ", "=", " ", 
     RowBox[{"boundedLapEquation", " ", "/.", " ", "shiftRules"}]}], ";"}], "\n", 
   RowBox[{"shiftCheck", " ", "=", " ", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{"shiftedEquation", " ", "-", " ", 
      RowBox[{"opS", "[", 
       RowBox[{"LLt", "[", "s", "]"}], "]"}]}], "]"}]}], "\n"}]}]], "Input",
 CellLabel->"In[22]:=",ExpressionUUID->"a5ce97f9-a169-4816-821b-14e7300aaf30"],

Cell[BoxData[
 RowBox[{
  FractionBox[
   RowBox[{"2", " ", 
    RowBox[{"(", 
     RowBox[{"4", "+", 
      SuperscriptBox["lam", "2"], "-", 
      RowBox[{"2", " ", "\[ImaginaryI]", " ", "s"}]}], ")"}], " ", "z1"}], 
   SuperscriptBox["lam", "2"]], "-", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"4", "+", 
     SuperscriptBox["lam", "2"], "-", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "s"}]}], ")"}], " ", 
   RowBox[{"LL", "[", "s", "]"}]}], "+", 
  RowBox[{"s", " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"2", " ", "\[ImaginaryI]"}], "+", "s"}], ")"}], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"6", " ", "\[ImaginaryI]"}], "+", 
        RowBox[{"4", " ", "s"}]}], ")"}], " ", 
      RowBox[{
       SuperscriptBox["LL", "\[Prime]",
        MultilineFunction->None], "[", "s", "]"}]}], "+", 
     RowBox[{"s", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", " ", "\[ImaginaryI]"}], "+", "s"}], ")"}], " ", 
      RowBox[{
       SuperscriptBox["LL", "\[Prime]\[Prime]",
