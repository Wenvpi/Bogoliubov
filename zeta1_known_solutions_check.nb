Cell[CellGroupData[{

Cell["5. Inverse Laplace transform checks", "Section",ExpressionUUID->"6c7f8b1a-3d96-4e3d-b061-70f36c7a56d6"],

Cell["\<\
These are the inverse transforms claimed in the PDF. If \
InverseLaplaceTransform itself returns a different form, the transform-back \
check is the more useful certification.\
\>", "Text",ExpressionUUID->"1edab0e1-c697-4387-9df2-0f99b5495a28"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\n", 
  RowBox[{
   RowBox[{
    RowBox[{"invPlusClaim", " ", "=", "\n", "   ", 
     RowBox[{
      RowBox[{"-", "I"}], " ", 
      RowBox[{"Exp", "[", 
       RowBox[{"Pi", " ", 
        RowBox[{"lam", "/", "2"}]}], "]"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", " ", "-", " ", 
           RowBox[{"I", " ", "lam"}]}], ")"}], " ", 
         RowBox[{"LaguerreL", "[", 
          RowBox[{
           RowBox[{"I", " ", 
            RowBox[{"lam", "/", "2"}]}], ",", " ", 
           RowBox[{
            RowBox[{"-", "2"}], " ", "I", " ", "x"}]}], "]"}]}], " ", "+", 
        "\n", "      ", 
        RowBox[{"I", " ", "lam", " ", 
         RowBox[{"Hypergeometric1F1", "[", 
          RowBox[{
           RowBox[{"1", " ", "-", " ", 
            RowBox[{"I", " ", 
             RowBox[{"lam", "/", "2"}]}]}], ",", " ", "2", ",", " ", 
           RowBox[{
            RowBox[{"-", "2"}], " ", "I", " ", "x"}]}], "]"}]}]}], ")"}]}]}], 
    ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"invMinusClaim", " ", "=", "\n", "   ", 
     RowBox[{
      RowBox[{"-", "I"}], " ", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "Pi"}], " ", 
        RowBox[{"lam", "/", "2"}]}], "]"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", " ", "+", " ", 
           RowBox[{"I", " ", "lam"}]}], ")"}], " ", 
         RowBox[{"LaguerreL", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"-", "I"}], " ", 
            RowBox[{"lam", "/", "2"}]}], ",", " ", 
           RowBox[{
            RowBox[{"-", "2"}], " ", "I", " ", "x"}]}], "]"}]}], " ", "-", 
        "\n", "      ", 
        RowBox[{"I", " ", "lam", " ", 
         RowBox[{"Hypergeometric1F1", "[", 
          RowBox[{
           RowBox[{"1", " ", "+", " ", 
            RowBox[{"I", " ", 
             RowBox[{"lam", "/", "2"}]}]}], ",", " ", "2", ",", " ", 
           RowBox[{
            RowBox[{"-", "2"}], " ", "I", " ", "x"}]}], "]"}]}]}], ")"}]}]}], 
    ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"directInvPlus", " ", "=", " ", 
     RowBox[{"TimeConstrained", "[", "\n", "   ", 
      RowBox[{
       RowBox[{"InverseLaplaceTransform", "[", 
        RowBox[{
         RowBox[{"lPlus", "[", "s", "]"}], ",", " ", "s", ",", " ", "x", ",", 
         " ", 
         RowBox[{"GenerateConditions", " ", "->", " ", "False"}]}], "]"}], ",",
        "\n", "   ", "60", ",", "\n", 
       "   ", "\"\<InverseLaplaceTransform timed out\>\""}], "\n", "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"directInvMinus", " ", "=", " ", 
     RowBox[{"TimeConstrained", "[", "\n", "   ", 
      RowBox[{
       RowBox[{"InverseLaplaceTransform", "[", 
        RowBox[{
         RowBox[{"lMinus", "[", "s", "]"}], ",", " ", "s", ",", " ", "x", ",",
          " ", 
         RowBox[{"GenerateConditions", " ", "->", " ", "False"}]}], "]"}], ",",
        "\n", "   ", "60", ",", "\n", 
       "   ", "\"\<InverseLaplaceTransform timed out\>\""}], "\n", "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"transformBackPlus", " ", "=", " ", 
     RowBox[{"TimeConstrained", "[", "\n", "   ", 
      RowBox[{
       RowBox[{"FullSimplify", "[", "\n", "     ", 
        RowBox[{
         RowBox[{"PowerExpand", "[", 
          RowBox[{
           RowBox[{"LaplaceTransform", "[", 
            RowBox[{"invPlusClaim", ",", " ", "x", ",", " ", "s", ",", " ", 
             RowBox[{"GenerateConditions", " ", "->", " ", "False"}]}], "]"}],
            " ", "-", " ", 
           RowBox[{"lPlus", "[", "s", "]"}]}], "]"}], ",", "\n", "     ", 
         RowBox[{"Assumptions", " ", "->", " ", "$Assumptions"}]}], "]"}], ",",
        "\n", "   ", "60", ",", "\n", 
       "   ", "\"\<LaplaceTransform check timed out\>\""}], "\n", "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"transformBackMinus", " ", "=", " ", 
     RowBox[{"TimeConstrained", "[", "\n", "   ", 
      RowBox[{
       RowBox[{"FullSimplify", "[", "\n", "     ", 
        RowBox[{
         RowBox[{"PowerExpand", "[", 
          RowBox[{
           RowBox[{"LaplaceTransform", "[", 
            RowBox[{"invMinusClaim", ",", " ", "x", ",", " ", "s", ",", " ", 
             RowBox[{"GenerateConditions", " ", "->", " ", "False"}]}], "]"}],
            " ", "-", " ", 
           RowBox[{"lMinus", "[", "s", "]"}]}], "]"}], ",", "\n", "     ", 
         RowBox[{"Assumptions", " ", "->", " ", "$Assumptions"}]}], "]"}], ",",
        "\n", "   ", "60", ",", "\n", 
       "   ", "\"\<LaplaceTransform check timed out\>\""}], "\n", "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"{", 
    RowBox[{
    "directInvPlus", ",", " ", "directInvMinus", ",", " ", 
     "transformBackPlus", ",", " ", "transformBackMinus"}], "}"}], 
   "\n"}]}]], "Input",
 CellLabel->"In[35]:=",ExpressionUUID->"4f762d14-c02a-4005-89bf-1f439cfda082"],

