Cell[CellGroupData[{

Cell["6. Define the two candidate solutions", "Section",ExpressionUUID->"b7cdccce-8537-4aa3-a5a6-536a28f4d141"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"f0", "[", "mu_", "]"}], " ", ":=", " ", 
     RowBox[{
      RowBox[{"Gamma", "[", 
       RowBox[{"1", " ", "+", " ", 
        RowBox[{"I", " ", 
         RowBox[{"mu", "/", "2"}]}]}], "]"}], " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", " ", "-", " ", 
         RowBox[{"I", " ", "mu"}]}], ")"}], "^", 
       RowBox[{"(", 
        RowBox[{"-", "1"}], ")"}]}], " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"2", " ", "I"}], ")"}], "^", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "I"}], " ", 
         RowBox[{"mu", "/", "2"}]}], ")"}]}]}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"zeta11", " ", "=", "\n", "   ", 
     RowBox[{
