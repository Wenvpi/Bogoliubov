Cell[CellGroupData[{

Cell["4. Check the transformed homogeneous basis", "Section",ExpressionUUID->"6a8fdc0b-3e73-41e3-be91-b1cf02ca819b"],

Cell["\<\
The Legendre basis is included for comparison, but the power basis is the one \
used for inverse Laplace transforms.\
\>", "Text",ExpressionUUID->"7a6ec44e-b798-4d90-abc9-b26b1fba8ae8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"lPlus", "[", "s_", "]"}], " ", ":=", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", " ", "-", " ", 
        RowBox[{"I", " ", "lam"}], " ", "-", " ", 
        RowBox[{"I", " ", "s"}]}], ")"}], " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"2", " ", "-", " ", 
         RowBox[{"I", " ", "s"}]}], ")"}], "^", 
       RowBox[{"(", 
        RowBox[{"I", " ", 
         RowBox[{"lam", "/", "2"}]}], ")"}]}], " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"I", " ", "s"}], ")"}], "^", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "I"}], " ", 
          RowBox[{"lam", "/", "2"}]}], " ", "-", " ", "1"}], ")"}]}]}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"lMinus", "[", "s_", "]"}], " ", ":=", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", " ", "+", " ", 
        RowBox[{"I", " ", "lam"}], " ", "-", " ", 
        RowBox[{"I", " ", "s"}]}], ")"}], " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"2", " ", "-", " ", 
         RowBox[{"I", " ", "s"}]}], ")"}], "^", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "I"}], " ", 
         RowBox[{"lam", "/", "2"}]}], ")"}]}], " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"I", " ", "s"}], ")"}], "^", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"I", " ", 
          RowBox[{"lam", "/", "2"}]}], " ", "-", " ", "1"}], ")"}]}]}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"lPlusResidual", " ", "=", " ", 
    RowBox[{"safeSimplify", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"opS", "[", 
        RowBox[{"lPlus", "[", "s", "]"}], "]"}], "/", 
       RowBox[{"lPlus", "[", "s", "]"}]}], ",", " ", "30"}], "]"}]}], "\n", 
   RowBox[{"lMinusResidual", " ", "=", " ", 
    RowBox[{"safeSimplify", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"opS", "[", 
        RowBox[{"lMinus", "[", "s", "]"}], "]"}], "/", 
       RowBox[{"lMinus", "[", "s", "]"}]}], ",", " ", "30"}], "]"}]}], "\n", "\n", 
   RowBox[{
    RowBox[{"pBasis", " ", "=", " ", 
     RowBox[{
      RowBox[{"LegendreP", "[", 
       RowBox[{"1", ",", " ", 
        RowBox[{"I", " ", "lam"}], ",", " ", 
        RowBox[{"1", " ", "-", " ", 
         RowBox[{"I", " ", "s"}]}]}], "]"}], "/", "s"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"pExplicit", " ", "=", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", " ", "-", " ", 
        RowBox[{"I", " ", "lam"}], " ", "-", " ", 
        RowBox[{"I", " ", "s"}]}], ")"}], " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"2", " ", "-", " ", 
         RowBox[{"I", " ", "s"}]}], ")"}], "^", 
       RowBox[{"(", 
        RowBox[{"I", " ", 
         RowBox[{"lam", "/", "2"}]}], ")"}]}], " ", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"I", " ", "s"}], ")"}], "^", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "I"}], " ", 
          RowBox[{"lam", "/", "2"}]}], ")"}]}], "/", 
       RowBox[{"(", 
        RowBox[{"s", " ", 
         RowBox[{"Gamma", "[", 
          RowBox[{"2", " ", "-", " ", 
           RowBox[{"I", " ", "lam"}]}], "]"}]}], ")"}]}]}]}], ";"}], "\n", 
   RowBox[{"pBasisCheck", " ", "=", " ", 
    RowBox[{"safeSimplify", "[", 
     RowBox[{
      RowBox[{"pBasis", " ", "-", " ", "pExplicit"}], ",", " ", "30"}], 
     "]"}]}], "\n"}]}]], "Input",
 CellLabel->"In[28]:=",ExpressionUUID->"95373b62-cd57-4896-ac88-75e09f278044"],

