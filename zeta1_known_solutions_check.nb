     RowBox[{"odeX", "[", "zeta12", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"symbolicResidual11", " ", "=", " ", 
    RowBox[{"safeSimplify", "[", 
     RowBox[{"res11", ",", " ", "90"}], "]"}]}], "\n", 
   RowBox[{"symbolicResidual12", " ", "=", " ", 
    RowBox[{"safeSimplify", "[", 
     RowBox[{"res12", ",", " ", "90"}], "]"}]}], "\n"}]}]], "Input",
 CellLabel->"In[46]:=",ExpressionUUID->"5616a12a-91cb-4656-92d4-b0a9031aa040"],

