Cell[CellGroupData[{

Cell["7. Direct substitution in the original fourth-order ODE", "Section",ExpressionUUID->"e43b449a-0825-4419-9199-bf5a4e5c22f5"],

Cell["\<\
The symbolic identity is hard for Mathematica because it requires \
hypergeometric contiguous relations. The notebook tries it, then performs \
high-precision numerical tests.\
\>", "Text",ExpressionUUID->"72bdec0a-f51b-49aa-8f5c-3d0829b75d6d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\n", 
