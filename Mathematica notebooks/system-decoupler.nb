Notebook[{

Cell[CellGroupData[{
Cell["Differential system decoupler", "Title",
 CellChangeTimes->{{3.988970989982605*^9, 
  3.9889709957591753`*^9}},ExpressionUUID->"5fdb1ee7-3ce4-456d-a3c4-\
0124a64b5aef"],

Cell["\<\
This notebook derives decoupled higher-order differential equations from \
first-order Bogoliubov systems.  The main idea is algebraic: start from a \
linear first-order system for a vector of Bogoliubov coefficients,\
\>", "Text",ExpressionUUID->"9b9fd36e-2eb7-4125-8a7b-07e0b76ff227"],

Cell[BoxData[
 FormBox[
  RowBox[{
   FractionBox["d", "dx"], "\[ScriptCapitalV]", "(", "x", ")", "\[LongEqual]",
    "\[DoubleStruckCapitalM]", "(", "x", ")", "\[ScriptCapitalV]", "(", "x", 
   ")"}], TraditionalForm]], "DisplayFormula",ExpressionUUID->"6021c81b-52be-\
4c37-9b4c-6fa7345c7218"],

Cell["\<\
and choose one component of the vector as the scalar function to decouple.\
\>", "Text",ExpressionUUID->"6e974563-34a4-4ebc-a189-36ec04d2fefb"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"y", "(", "x", ")"}], "\[LongEqual]", 
   RowBox[{
    SubscriptBox["\[DoubleStruckE]", "j"], "\[CenterDot]", 
    RowBox[{"\[ScriptCapitalV]", "(", "x", ")"}]}]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"5ba0ce14-3417-465c-\
b759-d1cacd361e35"],

Cell["\<\
All derivatives of this component can be written as row vectors acting on the \
same coefficient vector.  For a four-dimensional first-order system, the \
fifth row must be a linear combination of the previous four rows, producing a \
fourth-order ODE for the chosen component.\
\>", "Text",ExpressionUUID->"45cb570e-d9a2-4aef-8526-0541e95bca07"],

Cell["\<\
The notebook is organized in two parts.  The first part treats the massless \
two-field system used in the analytic solutions already derived in the notes. \
 The second part implements the more general system of Eqs. (4.70)-(4.73) of \
JHEP 03 (2022) 196, where the curvature mode remains massless while the \
isocurvature mode has mass \[Mu].\
\>", "Text",ExpressionUUID->"5c2b0cd0-7a42-46fb-88a0-d902e5a93fab"],

Cell[CellGroupData[{

Cell["Massless curvature isocurvature fields case", "Section",
 CellChangeTimes->{{3.988971007323998*^9, 3.988971019853944*^9}, {
  3.98897106233641*^9, 
  3.9889710650007677`*^9}},ExpressionUUID->"acab9e78-ba3b-490d-ba80-\
ceb69ab1e1dd"],

Cell[CellGroupData[{

Cell["Setup and decoupling algorithm", "Subsection",ExpressionUUID->"d8ece351-a93b-4193-b645-dd2d6b215b8c"],

Cell["In this section the coefficient vector is", "Text",ExpressionUUID->"c690832a-d43f-4c71-aa11-bacdc214aa0a"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"\[ScriptCapitalV]", "(", "x", ")"}], "\[LongEqual]", 
   RowBox[{"(", GridBox[{
      {
       RowBox[{
        SubscriptBox["\[Zeta]", "1"], "(", "x", ")"}]},
      {
       RowBox[{
        SubscriptBox["\[Zeta]", "2"], "(", "x", ")"}]},
      {
       RowBox[{
        SubscriptBox["\[Psi]", "1"], "(", "x", ")"}]},
      {
       RowBox[{
        SubscriptBox["\[Psi]", "2"], "(", "x", ")"}]}
     }], ")"}]}], TraditionalForm]], "DisplayFormula",ExpressionUUID->\
"93406e19-3195-4a3e-9562-3aa6df6dd5e2"],

Cell["The variable used in the notes is", "Text",ExpressionUUID->"28913df1-891b-4a29-a59a-3842959920df"],

Cell[BoxData[
 FormBox[
  RowBox[{"x", "\[LongEqual]", 
   SuperscriptBox["e", 
    RowBox[{"-", "t"}]], "\[LongEqual]", 
   FractionBox["k", 
    RowBox[{"a", " ", "H"}]], "\[LongEqual]", 
   RowBox[{"-", "k", " ", "\[Tau]"}]}], TraditionalForm]], "DisplayFormula",Ex\
pressionUUID->"95609098-6f2e-4d1b-93ae-45d570ec50b1"],

Cell["in exact de Sitter.  The first-order system is written as", "Text",ExpressionUUID->"e04425ac-cd0f-484b-b750-efe14664f9bd"],

Cell[BoxData[
 FormBox[
  RowBox[{
   FractionBox["d", "dx"], "\[ScriptCapitalV]", "(", "x", ")", "\[LongEqual]",
    "\[DoubleStruckCapitalM]", "(", "x", ")", "\[ScriptCapitalV]", "(", "x", 
   ")"}], TraditionalForm]], "DisplayFormula",ExpressionUUID->"6abc3056-7550-\
48f1-aeee-68333757a839"],

Cell["where the matrix is defined in the first input cell.", "Text",ExpressionUUID->"df997a9b-ce94-489f-8352-fafe511a753c"],

Cell["The labels used in the code are", "Text",ExpressionUUID->"668d2d67-1a54-4394-8b43-a4e514a97cbe"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"z1", 
    RowBox[{"\\[", "Longleftrightarrow", "]"}], 
    SubscriptBox["\[Zeta]", "1"]}], ",", "\[ThickSpace]", 
   RowBox[{"z2", 
    RowBox[{"\\[", "Longleftrightarrow", "]"}], 
    SubscriptBox["\[Zeta]", "2"]}], ",", "\[ThickSpace]", 
   RowBox[{"p1", 
    RowBox[{"\\[", "Longleftrightarrow", "]"}], 
    SubscriptBox["\[Psi]", "1"]}], ",", "\[ThickSpace]", 
   RowBox[{"p2", 
    RowBox[{"\\[", "Longleftrightarrow", "]"}], 
    SubscriptBox["\[Psi]", "2"]}]}], TraditionalForm]], "DisplayFormula",Expre\
ssionUUID->"d2c17b16-5d0c-425c-bcd8-cf20334b106d"],

Cell["\<\
The parameter lam is the constant coupling \[Lambda] during the feature.\
\>", "Text",ExpressionUUID->"2ad80984-bbba-4f29-87ea-8703261aaec0"],

Cell["For a row vector, the decoupling rule is", "Text",ExpressionUUID->"652f96d8-2a08-400e-8c32-a7cf3e255f20"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"y", "\[LongEqual]", 
    RowBox[{
    "\[DoubleStruckR]", "(", "x", ")", "\[ScriptCapitalV]", "(", "x", ")"}]}],
    "\[DoubleLongRightArrow]", 
   RowBox[{
    SuperscriptBox["y", "\[Prime]"], "\[LongEqual]", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["\[DoubleStruckR]", "\[Prime]"], "(", "x", ")", "+", 
       RowBox[{
       "\[DoubleStruckR]", "(", "x", ")", "\[DoubleStruckCapitalM]", "(", "x",
         ")"}]}], ")"}], "\[ScriptCapitalV]", "(", "x", ")"}]}]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"3e759413-165b-4bbb-\
b95a-caab22048ae2"],

Cell["\<\
The function rowDerivative implements this rule.  Starting from the unit row \
that selects a component, the notebook builds the rows corresponding to\
\>", "Text",ExpressionUUID->"15e0c09a-5978-4b85-8ccc-c367556f8498"],

Cell[BoxData[
 FormBox[
  RowBox[{"y", ",", 
   SuperscriptBox["y", "\[Prime]"], ",", 
   SuperscriptBox["y", "\[Prime]\[Prime]"], ",", 
   SuperscriptBox["y", "\[Prime]\[Prime]\[Prime]"], ",", 
   SuperscriptBox["y", 
    RowBox[{"(", "4", ")"}]]}], TraditionalForm]], "DisplayFormula",Expression\
UUID->"ed93ba6d-a895-4c58-ace9-7ebac405a301"],

Cell["The decoupled ODE is obtained by solving the row relation", "Text",ExpressionUUID->"6862cc10-84cf-413d-a6ba-20a73b4cc3ba"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["\[DoubleStruckR]", "4"], "\[LongEqual]", 
   RowBox[{
    SubscriptBox["c", "0"], 
    SubscriptBox["\[DoubleStruckR]", "0"], "+", 
    SubscriptBox["c", "1"], 
    SubscriptBox["\[DoubleStruckR]", "1"], "+", 
    SubscriptBox["c", "2"], 
    SubscriptBox["\[DoubleStruckR]", "2"], "+", 
    SubscriptBox["c", "3"], 
    SubscriptBox["\[DoubleStruckR]", "3"]}]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"84544cc8-6984-4b23-\
8ec6-5cd8b5075344"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "==="}], "*)"}], 
  
  RowBox[{"(*", 
   RowBox[{
   "Clean", " ", "decoupling", " ", "check", " ", "for", " ", "the", " ", 
    "massless", " ", "zeta_", "1", " ", "equation"}], "*)"}], 
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "==="}], "*)"}], 
  
  RowBox[{
   RowBox[{
    RowBox[{"Clear", "[", 
     RowBox[{
     "x", ",", "lam", ",", "z1", ",", "z2", ",", "p1", ",", "p2", ",", "vars",
       ",", "M", ",", "rowDerivative", ",", "decoupleComponent", ",", "odeZ1",
       ",", "lhsZ1", ",", "coeffsZ1", ",", "expectedCoeffsZ1", ",", 
      "coeffCheckZ1", ",", "knownZ1ODE", ",", "derivedZ1Monic", ",", 
      "knownZ1Monic", ",", "zeroCheckZ1"}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"vars", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"z1", "[", "x", "]"}], ",", 
       RowBox[{"z2", "[", "x", "]"}], ",", 
       RowBox[{"p1", "[", "x", "]"}], ",", 
       RowBox[{"p2", "[", "x", "]"}]}], "}"}]}], ";"}], "\[IndentingNewLine]",
    "\n", 
   RowBox[{
    RowBox[{"M", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", 
         RowBox[{"I", " ", 
          RowBox[{"lam", "/", 
           RowBox[{"(", 
            RowBox[{"2", " ", 
             RowBox[{"x", "^", "2"}]}], ")"}]}], " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"I", " ", "x"}], "-", "1"}], ")"}]}], ",", 
         RowBox[{"I", " ", 
          RowBox[{"lam", "/", 
           RowBox[{"(", 
            RowBox[{"2", " ", 
             RowBox[{"x", "^", "2"}]}], ")"}]}], " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"I", " ", "x"}], "+", "1"}], ")"}], " ", 
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{"-", "2"}], " ", "I", " ", "x"}], "]"}]}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", 
         RowBox[{"I", " ", 
          RowBox[{"lam", "/", 
           RowBox[{"(", 
            RowBox[{"2", " ", 
             RowBox[{"x", "^", "2"}]}], ")"}]}], " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"I", " ", "x"}], "-", "1"}], ")"}], " ", 
          RowBox[{"Exp", "[", 
           RowBox[{"2", " ", "I", " ", "x"}], "]"}]}], ",", 
         RowBox[{"I", " ", 
          RowBox[{"lam", "/", 
           RowBox[{"(", 
            RowBox[{"2", " ", 
             RowBox[{"x", "^", "2"}]}], ")"}]}], " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"I", " ", "x"}], "+", "1"}], ")"}]}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "I"}], " ", 
          RowBox[{"lam", "/", 
           RowBox[{"(", 
            RowBox[{"2", " ", 
             RowBox[{"x", "^", "2"}]}], ")"}]}], " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"I", " ", "x"}], "+", "1"}], ")"}]}], ",", 
         RowBox[{"I", " ", 
          RowBox[{"lam", "/", 
           RowBox[{"(", 
            RowBox[{"2", " ", 
             RowBox[{"x", "^", "2"}]}], ")"}]}], " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"I", " ", "x"}], "+", "1"}], ")"}], " ", 
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{"-", "2"}], " ", "I", " ", "x"}], "]"}]}], ",", "0", ",", 
         "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"I", " ", 
          RowBox[{"lam", "/", 
           RowBox[{"(", 
            RowBox[{"2", " ", 
             RowBox[{"x", "^", "2"}]}], ")"}]}], " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"I", " ", "x"}], "-", "1"}], ")"}], " ", 
          RowBox[{"Exp", "[", 
           RowBox[{"2", " ", "I", " ", "x"}], "]"}]}], ",", 
         RowBox[{
          RowBox[{"-", "I"}], " ", 
          RowBox[{"lam", "/", 
           RowBox[{"(", 
            RowBox[{"2", " ", 
             RowBox[{"x", "^", "2"}]}], ")"}]}], " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"I", " ", "x"}], "-", "1"}], ")"}]}], ",", "0", ",", 
         "0"}], "}"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"rowDerivative", "[", "row_", "]"}], ":=", 
     RowBox[{"Together", "[", 
      RowBox[{
       RowBox[{"D", "[", 
        RowBox[{"row", ",", "x"}], "]"}], "+", 
       RowBox[{"row", ".", "M"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"decoupleComponent", "[", "index_Integer", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "e0", ",", "rows", ",", "R", ",", "b", ",", "coeffs", ",", "target", ",",
          "ode", ",", "n"}], "}"}], ",", 
       RowBox[{
        RowBox[{"n", "=", 
         RowBox[{"Length", "[", "vars", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"e0", "=", 
         RowBox[{"UnitVector", "[", 
          RowBox[{"n", ",", "index"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"rows", "=", 
         RowBox[{"NestList", "[", 
          RowBox[{"rowDerivative", ",", "e0", ",", "n"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"Solve", " ", "row4"}], "=", 
          RowBox[{
           RowBox[{"c0", " ", "row0"}], "+", 
           RowBox[{"c1", " ", "row1"}], "+", 
           RowBox[{"c2", " ", "row2"}], "+", 
           RowBox[{"c3", " ", "row3"}]}]}], "*)"}], 
        RowBox[{"R", "=", 
         RowBox[{"rows", "[", 
          RowBox[{"[", 
           RowBox[{"1", ";;", "n"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"b", "=", 
         RowBox[{"rows", "[", 
          RowBox[{"[", 
           RowBox[{"n", "+", "1"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"coeffs", "=", 
         RowBox[{"LinearSolve", "[", 
          RowBox[{
           RowBox[{"Transpose", "[", "R", "]"}], ",", "b"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"target", "=", 
         RowBox[{"vars", "[", 
          RowBox[{"[", "index", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"ode", "=", 
         RowBox[{
          RowBox[{"Together", "[", 
           RowBox[{
            RowBox[{"D", "[", 
             RowBox[{"target", ",", 
              RowBox[{"{", 
               RowBox[{"x", ",", "n"}], "}"}]}], "]"}], "-", 
            RowBox[{"Sum", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"coeffs", "[", 
                RowBox[{"[", "j", "]"}], "]"}], " ", 
               RowBox[{"D", "[", 
                RowBox[{"target", ",", 
                 RowBox[{"{", 
                  RowBox[{"x", ",", 
                   RowBox[{"j", "-", "1"}]}], "}"}]}], "]"}]}], ",", 
              RowBox[{"{", 
               RowBox[{"j", ",", "1", ",", "n"}], "}"}]}], "]"}]}], "]"}], "==",
           "0"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<Rows\>\"", "->", "rows"}], ",", 
          RowBox[{"\"\<Coefficients\>\"", "->", "coeffs"}], ",", 
          RowBox[{"\"\<ODE\>\"", "->", "ode"}]}], "|>"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"odeZ1", "=", 
     RowBox[{"decoupleComponent", "[", "1", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"coeffsZ1", "=", 
     RowBox[{"Together", "[", 
      RowBox[{"odeZ1", "[", "\"\<Coefficients\>\"", "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"coeffsZ1", "//", "TraditionalForm"}]}]}]], "Input",
 CellChangeTimes->{{3.988969337273006*^9, 3.988969337274502*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"6d1e8276-c680-4143-b8e0-681eeb76bd4d"],

Cell[BoxData[
 FormBox[
  RowBox[{"{", 
   RowBox[{
    FractionBox[
     SuperscriptBox["lam", "2"], 
     SuperscriptBox["x", "2"]], ",", 
    FractionBox[
     RowBox[{"2", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", " ", "x"}], "+", "\[ImaginaryI]"}], ")"}]}], 
     SuperscriptBox["x", "2"]], ",", 
    FractionBox[
     RowBox[{"2", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", " ", "x"}], "-", 
        RowBox[{"5", " ", "\[ImaginaryI]"}]}], ")"}]}], "x"], ",", 
    RowBox[{"-", 
     FractionBox[
      RowBox[{"4", " ", "\[ImaginaryI]", " ", 
       RowBox[{"(", 
        RowBox[{"x", "-", "\[ImaginaryI]"}], ")"}]}], "x"]}]}], "}"}], 
  TraditionalForm]], "Output",
 CellChangeTimes->{3.988969340548284*^9, 3.9889701404345503`*^9, 
  3.9889710722784357`*^9},
 CellLabel->
  "Out[8]//TraditionalForm=",ExpressionUUID->"db13b410-12b9-401d-81d5-\
42ba6ab023c6"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Known zeta1 equation check", "Subsection",ExpressionUUID->"6ca4cd3d-3095-435c-bf3b-aaab188729fa"],

Cell["\<\
The first output lists the coefficients for the decoupled zeta1 equation in \
the convention\
\>", "Text",ExpressionUUID->"53b3d0c7-47aa-4a57-bc1c-611bb4d6f414"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SuperscriptBox[
    SubscriptBox["\[Zeta]", "1"], 
    RowBox[{"(", "4", ")"}]], "\[LongEqual]", 
   RowBox[{
    SubscriptBox["c", "0"], 
    SubscriptBox["\[Zeta]", "1"], "+", 
    SubscriptBox["c", "1"], 
    SuperscriptBox[
     SubscriptBox["\[Zeta]", "1"], "\[Prime]"], "+", 
    SubscriptBox["c", "2"], 
    SuperscriptBox[
     SubscriptBox["\[Zeta]", "1"], "\[Prime]\[Prime]"], "+", 
    SubscriptBox["c", "3"], 
    SuperscriptBox[
     SubscriptBox["\[Zeta]", "1"], "\[Prime]\[Prime]\[Prime]"]}]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"ca563a0d-ca71-4053-\
a3c4-8c9248ca6f2c"],

Cell["\<\
The following cell checks these coefficients against the fourth-order \
equation already derived in the notes.  A result {0,0,0,0} means the \
decoupling has reproduced the known zeta1 ODE.\
\>", "Text",ExpressionUUID->"30aacf38-e73e-4ae0-a5d6-65273fd83acd"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "==="}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Coefficient", " ", "check"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "==="}], "*)"}], 
  
  RowBox[{
   RowBox[{
    RowBox[{"expectedCoeffsZ1", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"lam", "^", "2"}], "/", 
        RowBox[{"x", "^", "2"}]}], ",", 
       RowBox[{"2", " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"2", " ", "x"}], "+", "I"}], ")"}], "/", 
         RowBox[{"x", "^", "2"}]}]}], ",", 
       RowBox[{"2", " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"2", " ", "x"}], "-", 
           RowBox[{"5", " ", "I"}]}], ")"}], "/", "x"}]}], ",", 
       RowBox[{
        RowBox[{"-", "4"}], " ", "I", " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"x", "-", "I"}], ")"}], "/", "x"}]}]}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"coeffCheckZ1", "=", 
     RowBox[{"Together", "[", 
      RowBox[{"coeffsZ1", "-", "expectedCoeffsZ1"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"coeffCheckZ1", "//", "TraditionalForm"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"This", " ", "should", " ", "return", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", "0", ",", "0", ",", "0"}], "}"}], "."}]}], 
    "*)"}]}]}]], "Input",
 CellChangeTimes->{{3.9889693560486383`*^9, 3.988969356051516*^9}, {
  3.988971077261468*^9, 
  3.9889710791760073`*^9}},ExpressionUUID->"e95836dc-f587-4b42-9977-\
84e10d19f5dc"],

Cell[BoxData[
 FormBox[
  RowBox[{"{", 
   RowBox[{"0", ",", "0", ",", "0", ",", "0"}], "}"}], 
