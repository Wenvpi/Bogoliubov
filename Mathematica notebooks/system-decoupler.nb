  RowBox[{"pullDenominatorForDisplay", "[", "expr_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"exprNumerator", ",", "exprDenominator"}], "}"}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"exprNumerator", ",", "exprDenominator"}], "}"}], "=", 
      RowBox[{"NumeratorDenominator", "[", 
       RowBox[{"Together", "[", "expr", "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"exprDenominator", "===", "1"}], ",", 
       RowBox[{"Factor", "[", "exprNumerator", "]"}], ",", 
       RowBox[{
        RowBox[{"Inactive", "[", "Times", "]"}], "[", 
        RowBox[{
         RowBox[{"1", "/", "exprDenominator"}], ",", 
         RowBox[{"Factor", "[", "exprNumerator", "]"}]}], "]"}]}], "]"}]}]}], 
   "]"}]}]}], "Input",
