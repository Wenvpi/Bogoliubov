Cell[CellGroupData[{

Cell["Decoupled equations for all components", "Subsection",ExpressionUUID->"a7dabb0b-4455-49ee-81db-f31092389f2e"],

Cell["\<\
After the coefficient check, the same decoupling function is applied to all \
four components.  The ordering is\
\>", "Text",ExpressionUUID->"e5a21058-2976-4785-97cf-831a354a1fef"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"1", "\[Rule]", 
    SubscriptBox["\[Zeta]", "1"]}], ",", "\[ThickSpace]", 
   RowBox[{"2", "\[Rule]", 
    SubscriptBox["\[Zeta]", "2"]}], ",", "\[ThickSpace]", 
   RowBox[{"3", "\[Rule]", 
    SubscriptBox["\[Psi]", "1"]}], ",", "\[ThickSpace]", 
   RowBox[{"4", "\[Rule]", 
    SubscriptBox["\[Psi]", "2"]}]}], TraditionalForm]], "DisplayFormula",Expre\
ssionUUID->"b56cefc6-33ab-43b2-b534-065a44324033"],

Cell["\<\
Since the system has four first-order variables, each component generically \
satisfies a fourth-order scalar ODE.\
\>", "Text",ExpressionUUID->"625c2cc7-850f-4d7b-97ed-21dae7e74626"],

