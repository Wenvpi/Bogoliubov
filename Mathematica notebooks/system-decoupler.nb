          RowBox[{"3", " ", "\[ImaginaryI]", " ", 
           SuperscriptBox["x", "5"], " ", 
           RowBox[{
            SuperscriptBox[
             SubscriptBox["\[Psi]", "2"], 
             TagBox[
              RowBox[{"(", "4", ")"}],
              Derivative],
             MultilineFunction->None], "(", "x", ")"}]}], "-", 
          RowBox[{"18", " ", "\[ImaginaryI]", " ", 
           SuperscriptBox["x", "4"], " ", 
           RowBox[{
            SuperscriptBox[
             SubscriptBox["\[Psi]", "2"], "\[Prime]",
             MultilineFunction->None], "(", "x", ")"}]}], "+", 
          RowBox[{"54", " ", 
           SuperscriptBox["x", "4"], " ", 
           RowBox[{
            SuperscriptBox[
             SubscriptBox["\[Psi]", "2"], "\[Prime]\[Prime]",
             MultilineFunction->None], "(", "x", ")"}]}], "+", 
          RowBox[{"28", " ", "\[ImaginaryI]", " ", 
           SuperscriptBox["x", "4"], " ", 
           RowBox[{
            SuperscriptBox[
             SubscriptBox["\[Psi]", "2"], 
