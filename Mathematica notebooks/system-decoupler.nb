Cell[CellGroupData[{

Cell["Massless curvature and massive isocurvature fields case", "Section",
 CellChangeTimes->{{3.988970876447175*^9, 3.988970884317115*^9}, {
  3.988971026624373*^9, 
  3.988971048883462*^9}},ExpressionUUID->"f1f6fe2f-fd74-4b09-95ff-\
fdf0d0c8a778"],

Cell[CellGroupData[{

Cell["Dictionary with the paper notation", "Subsection",ExpressionUUID->"2d23e075-7933-45d0-ba05-f9930266ec81"],

Cell["\<\
This section implements the first-order Bogoliubov system of Eqs. \
(4.70)-(4.73) of JHEP 03 (2022) 196.  The paper writes the fields using \
time-dependent Bogoliubov coefficients\
\>", "Text",ExpressionUUID->"05b4f3d7-d93c-4d90-982b-bf3dfe564fd8"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["\[Alpha]", 
    RowBox[{"\[Zeta]", "i"}]], ",", "\[ThickSpace]", 
   SubscriptBox["\[Beta]", 
    RowBox[{"\[Zeta]", "i"}]], ",", "\[ThickSpace]", 
   SubscriptBox["\[Alpha]", 
    RowBox[{"\[Psi]", "i"}]], ",", "\[ThickSpace]", 
   SubscriptBox["\[Beta]", 
    RowBox[{"\[Psi]", "i"}]]}], TraditionalForm]], "DisplayFormula",Expression\
UUID->"c33c69fe-2530-476b-a188-0e81ebffab69"],

Cell["In the notation of these notes, these are renamed as", "Text",ExpressionUUID->"fbbda608-b0bc-4eb7-ac70-0dadacba36e0"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"z1", 
    RowBox[{"\\[", "Longleftrightarrow", "]"}], 
    SubscriptBox["\[Zeta]", "1"]}], ",", "\[ThickSpace]", 
   RowBox[{"z2", 
    RowBox[{"\\[", "Longleftrightarrow", "]"}], 
    SubscriptBox["\[Zeta]", "2"]}], ",", "\[ThickSpace]", 
   RowBox[{"p1", 
    RowBox[{"\\[", "Longleftrightarrow", "]"}], 
    SubscriptBox["\[Psi]", "1"]}], ",", "\[ThickSpace]", 
   RowBox[{"p2", 
    RowBox[{"\\[", "Longleftrightarrow", "]"}], 
    SubscriptBox["\[Psi]", "2"]}]}], TraditionalForm]], "DisplayFormula",Expre\
ssionUUID->"3160c2db-731a-4597-80c5-8b760be3ec53"],

Cell["The curvature mode is kept massless:", "Text",ExpressionUUID->"d3f45384-084a-4125-9a6a-d818002d0f71"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"\[Zeta]", "(", 
    RowBox[{"k", " ", "\[Tau]"}], ")"}], "\[LongEqual]", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{"i", " ", "k", " ", "\[Tau]"}]}], ")"}], 
    SuperscriptBox["e", 
     RowBox[{"-", "i", " ", "k", " ", "\[Tau]"}]]}]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"0e43af46-9a23-4806-\
b6e3-5f69404ccb05"],

Cell["The isocurvature mode is massive:", "Text",ExpressionUUID->"206fb722-7f86-44d8-91ea-a92a3828811f"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"\[Psi]", "(", 
    RowBox[{"k", " ", "\[Tau]"}], ")"}], "\[LongEqual]", 
   RowBox[{"i", 
    SqrtBox[
     FractionBox["\[Pi]", "2"]], 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"-", "k", " ", "\[Tau]"}], ")"}], 
     RowBox[{"3", "/", "2"}]], 
    RowBox[{
     SubsuperscriptBox["H", "\[Nu]", 
      RowBox[{"(", "1", ")"}]], "(", 
     RowBox[{"-", "k", " ", "\[Tau]"}], ")"}]}]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"e96c6123-86b9-4ed0-\
bac7-ff508b7aea34"],

Cell[BoxData[
 FormBox[
  RowBox[{"\[Nu]", "\[LongEqual]", 
   SqrtBox[
    RowBox[{
     FractionBox["9", "4"], "-", 
     FractionBox[
      SuperscriptBox["\[Mu]", "2"], 
      SuperscriptBox["H", "2"]]}]]}], TraditionalForm]], "DisplayFormula",Expr\
essionUUID->"7eb728a7-8730-4080-afcc-151ab9aae6f8"],

Cell["\<\
The conjugate mode is represented with the Hankel function of the second \
kind, which is the appropriate conjugate for real \[Nu] and real positive -k \
\[Tau].\
\>", "Text",ExpressionUUID->"53666103-523b-452b-8ad6-076229363fca"],

Cell["\<\
The coupling in the paper is the bending parameter eta_perp(tau).  In this \
notebook it is denoted by eta and is treated as the constant coupling during \
the feature, playing the same role that \[Lambda] played in the massless \
system.  The mass parameter \[Mu] enters only through the Hankel index \[Nu]; \
setting \[Mu] = 0 gives \[Nu] = 3/2, the massless de Sitter value.\
\>", "Text",ExpressionUUID->"a7e0cbac-d281-4587-ad87-8df8666c7d9f"],

Cell["The matrix Mmassive is assembled directly from Eq. (4.73):", "Text",ExpressionUUID->"b55f4050-8e3c-4833-a5c7-e341aeda0abd"],

Cell[BoxData[
 FormBox[
  RowBox[{
   FractionBox["d", 
    RowBox[{"d", "\[Tau]"}]], 
   RowBox[{"(", GridBox[{
      {
       SubscriptBox["\[Zeta]", "1"]},
      {
       SubscriptBox["\[Zeta]", "2"]}
     }], ")"}], "\[LongEqual]", 
   RowBox[{"\[ScriptCapitalA]", "(", 
    RowBox[{"k", ",", "\[Tau]"}], ")", 
    RowBox[{"(", GridBox[{
       {
        SubscriptBox["\[Psi]", "1"]},
       {
        SubscriptBox["\[Psi]", "2"]}
      }], ")"}]}]}], TraditionalForm]], "DisplayFormula",ExpressionUUID->\
"dd4d9d68-e74c-4f3a-9331-e437b49dfd1d"],

Cell[BoxData[
 FormBox[
  RowBox[{
   FractionBox["d", 
    RowBox[{"d", "\[Tau]"}]], 
   RowBox[{"(", GridBox[{
      {
       SubscriptBox["\[Psi]", "1"]},
      {
       SubscriptBox["\[Psi]", "2"]}
     }], ")"}], "\[LongEqual]", 
   RowBox[{"\[ScriptCapitalB]", "(", 
    RowBox[{"k", ",", "\[Tau]"}], ")", 
    RowBox[{"(", GridBox[{
       {
        SubscriptBox["\[Zeta]", "1"]},
       {
        SubscriptBox["\[Zeta]", "2"]}
      }], ")"}]}]}], TraditionalForm]], "DisplayFormula",ExpressionUUID->\
"c7b908d3-1fd9-439a-846b-3112f03b5051"],

Cell["\<\
Once this matrix is defined, the decoupling algorithm is exactly the same as \
in the massless section.\
\>", "Text",ExpressionUUID->"d4f829b7-c768-4b09-829d-9e9662071855"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Massive system and decoupling", "Subsection",ExpressionUUID->"d8de3337-49e6-42e1-8a1d-8b64f235412a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "==="}], "*)"}], 
  
  RowBox[{"(*", 
   RowBox[{"Massive", "-", 
    RowBox[{
    "isocurvature", " ", "Bogoliubov", " ", "system", " ", "and", " ", 
     "decoupling"}]}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Based", " ", "on", " ", "JHEP", " ", "03", " ", 
     RowBox[{"(", "2022", ")"}], " ", "196"}], ",", 
    RowBox[{
     RowBox[{"Eqs", ".", 
      RowBox[{"(", "4.70", ")"}]}], "-", 
     RowBox[{"(", "4.73", ")"}]}]}], "*)"}], 
  RowBox[{"(*", "*)"}], 
  RowBox[{"(*", 
   RowBox[{"Dictionary", " ", "with", " ", "our", " ", 
    RowBox[{"notation", ":"}]}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"z1", "[", "tau", "]"}], "=", "alpha_zeta"}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"z2", "[", "tau", "]"}], "=", "beta_zeta"}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"p1", "[", "tau", "]"}], "=", "alpha_psi"}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"p2", "[", "tau", "]"}], "=", "beta_psi"}], "*)"}], 
  RowBox[{"(*", "*)"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"zeta", " ", "is", " ", "massless"}], ",", 
    RowBox[{"psi", " ", "has", " ", "mass", " ", 
     RowBox[{"mu", "."}]}]}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"eta", " ", "is", " ", "eta_perp"}], ",", 
    RowBox[{"the", " ", "coupling", " ", "during", " ", "the", " ", 
     RowBox[{"turn", "."}]}]}], "*)"}], 
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "==="}], "*)"}], 
  
  RowBox[{
   RowBox[{
    RowBox[{"Clear", "[", 
     RowBox[{
     "tau", ",", "k", ",", "eta", ",", "mu", ",", "H", ",", "nu", ",", 
      "zetaMode", ",", "zetaStarMode", ",", "psiMode", ",", "psiStarMode", ",",
       "zetaPrime", ",", "zetaStarPrime", ",", "z1", ",", "z2", ",", "p1", ",",
       "p2", ",", "varsMassive", ",", "Mmassive", ",", "rowDerivativeMassive",
       ",", "decoupleComponentMassive", ",", "odeZ1Massive", ",", 
      "odeZ2Massive", ",", "odeP1Massive", ",", "odeP2Massive", ",", 
      "lhsZ1Massive", ",", "lhsZ2Massive", ",", "lhsP1Massive", ",", 
      "lhsP2Massive"}], "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"Massive", " ", "index", " ", "from", " ", "the", " ", 
       RowBox[{"paper", ":", 
        RowBox[{"psi", 
         RowBox[{"(", 
          RowBox[{"k", " ", "tau"}], ")"}]}]}]}], "=", 
      RowBox[{"i", " ", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"Pi", "/", "2"}], "]"}], " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "k"}], " ", "tau"}], ")"}], "^", 
        RowBox[{"(", 
         RowBox[{"3", "/", "2"}], ")"}]}], " ", 
       RowBox[{"HankelH1", "[", 
        RowBox[{"nu", ",", 
         RowBox[{
          RowBox[{"-", "k"}], " ", "tau"}]}], "]"}]}]}], ",", 
     RowBox[{"nu", "=", 
      RowBox[{
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"9", "/", "4"}], "-", 
         RowBox[{
          RowBox[{"mu", "^", "2"}], "/", 
          RowBox[{"H", "^", "2"}]}]}], "]"}], "."}]}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"nu", "=", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{"9", "/", "4"}], "-", 
       RowBox[{
        RowBox[{"mu", "^", "2"}], "/", 
        RowBox[{"H", "^", "2"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Massless", " ", "curvature", " ", "mode"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"zetaMode", "[", "tau_", "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "+", 
        RowBox[{"I", " ", "k", " ", "tau"}]}], ")"}], " ", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "I"}], " ", "k", " ", "tau"}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"zetaStarMode", "[", "tau_", "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{"I", " ", "k", " ", "tau"}]}], ")"}], " ", 
      RowBox[{"Exp", "[", 
       RowBox[{"I", " ", "k", " ", "tau"}], "]"}]}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"zetaPrime", "[", "tau_", "]"}], ":=", 
     RowBox[{"D", "[", 
      RowBox[{
       RowBox[{"zetaMode", "[", "tau", "]"}], ",", "tau"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"zetaStarPrime", "[", "tau_", "]"}], ":=", 
     RowBox[{"D", "[", 
      RowBox[{
       RowBox[{"zetaStarMode", "[", "tau", "]"}], ",", "tau"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"Massive", " ", "isocurvature", " ", 
       RowBox[{"mode", ".", "For"}], " ", "real", " ", "nu", " ", "and", " ", 
       "real", " ", "positive"}], "-", 
      RowBox[{"k", " ", "tau"}]}], ",", 
     RowBox[{"the", " ", "conjugate", " ", "of", " ", "HankelH1", " ", "is", " ", 
      RowBox[{"HankelH2", "."}]}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"psiMode", "[", "tau_", "]"}], ":=", 
     RowBox[{"I", " ", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"Pi", "/", "2"}], "]"}], " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "k"}], " ", "tau"}], ")"}], "^", 
       RowBox[{"(", 
        RowBox[{"3", "/", "2"}], ")"}]}], " ", 
      RowBox[{"HankelH1", "[", 
       RowBox[{"nu", ",", 
        RowBox[{
         RowBox[{"-", "k"}], " ", "tau"}]}], "]"}]}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"psiStarMode", "[", "tau_", "]"}], ":=", 
     RowBox[{
      RowBox[{"-", "I"}], " ", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"Pi", "/", "2"}], "]"}], " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "k"}], " ", "tau"}], ")"}], "^", 
       RowBox[{"(", 
        RowBox[{"3", "/", "2"}], ")"}]}], " ", 
      RowBox[{"HankelH2", "[", 
       RowBox[{"nu", ",", 
        RowBox[{
         RowBox[{"-", "k"}], " ", "tau"}]}], "]"}]}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"varsMassive", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"z1", "[", "tau", "]"}], ",", 
       RowBox[{"z2", "[", "tau", "]"}], ",", 
       RowBox[{"p1", "[", "tau", "]"}], ",", 
       RowBox[{"p2", "[", "tau", "]"}]}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"First", "-", 
      RowBox[{"order", " ", 
       RowBox[{"system", ":", 
        RowBox[{
         RowBox[{"d", "/", "dtau"}], " ", 
         RowBox[{"{", 
          RowBox[{"z1", ",", "z2"}], "}"}]}]}]}]}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{"A", ".", 
        RowBox[{"{", 
         RowBox[{"p1", ",", "p2"}], "}"}]}], " ", 
       RowBox[{"d", "/", "dtau"}], " ", 
       RowBox[{"{", 
        RowBox[{"p1", ",", "p2"}], "}"}]}], "=", 
      RowBox[{
       RowBox[{
        RowBox[{"B", ".", 
         RowBox[{"{", 
          RowBox[{"z1", ",", "z2"}], "}"}]}], " ", "A"}], "=", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "i"}], " ", 
         RowBox[{"eta", "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"k", "^", "3"}], " ", 
            RowBox[{"tau", "^", "3"}]}], ")"}]}], " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"zetaStarPrime", " ", "psi"}], ",", 
             RowBox[{"zetaStarPrime", " ", "psiStar"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{"-", "zetaPrime"}], " ", "psi"}], ",", 
             RowBox[{
              RowBox[{"-", "zetaPrime"}], " ", "psiStar"}]}], "}"}]}], "}"}], 
         " ", "B"}], "=", 
        RowBox[{"i", " ", 
         RowBox[{"eta", "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"k", "^", "3"}], " ", 
            RowBox[{"tau", "^", "3"}]}], ")"}]}], " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{"-", "zetaPrime"}], " ", "psiStar"}], ",", 
             RowBox[{
              RowBox[{"-", "zetaStarPrime"}], " ", "psiStar"}]}], "}"}], ",", 
           
           RowBox[{"{", 
            RowBox[{
             RowBox[{"zetaPrime", " ", "psi"}], ",", 
             RowBox[{"zetaStarPrime", " ", "psi"}]}], "}"}]}], 
          "}"}]}]}]}]}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"Mmassive", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", 
         RowBox[{
          RowBox[{"-", "I"}], " ", 
          RowBox[{"eta", "/", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"k", "^", "3"}], " ", 
             RowBox[{"tau", "^", "3"}]}], ")"}]}], " ", 
          RowBox[{"zetaStarPrime", "[", "tau", "]"}], " ", 
          RowBox[{"psiMode", "[", "tau", "]"}]}], ",", 
         RowBox[{
          RowBox[{"-", "I"}], " ", 
          RowBox[{"eta", "/", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"k", "^", "3"}], " ", 
             RowBox[{"tau", "^", "3"}]}], ")"}]}], " ", 
          RowBox[{"zetaStarPrime", "[", "tau", "]"}], " ", 
          RowBox[{"psiStarMode", "[", "tau", "]"}]}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", 
         RowBox[{"I", " ", 
          RowBox[{"eta", "/", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"k", "^", "3"}], " ", 
             RowBox[{"tau", "^", "3"}]}], ")"}]}], " ", 
          RowBox[{"zetaPrime", "[", "tau", "]"}], " ", 
          RowBox[{"psiMode", "[", "tau", "]"}]}], ",", 
         RowBox[{"I", " ", 
          RowBox[{"eta", "/", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"k", "^", "3"}], " ", 
