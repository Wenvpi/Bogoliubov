              RowBox[{"(", "3", ")"}],
              Derivative],
             MultilineFunction->None], "(", "x", ")"}]}], "-", 
          RowBox[{"3", " ", 
           SuperscriptBox["x", "4"], " ", 
           RowBox[{
            SuperscriptBox[
