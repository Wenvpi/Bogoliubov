          RowBox[{"(", 
           RowBox[{
            RowBox[{"I", " ", "x"}], "-", "1"}], ")"}]}], ",", "0", ",", 
         "0"}], "}"}]}], "}"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"rowDerivative", "[", "row_", "]"}], ":=", 
     RowBox[{"Together", "[", 
      RowBox[{
       RowBox[{"D", "[", 
        RowBox[{"row", ",", "x"}], "]"}], "+", 
       RowBox[{"row", ".", "M"}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"decoupleComponent", "[", "index_Integer", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "e0", ",", "rows", ",", "R", ",", "b", ",", "coeffs", ",", "target", ",",
          "ode", ",", "n"}], "}"}], ",", 
       RowBox[{
        RowBox[{"n", "=", 
         RowBox[{"Length", "[", "vars", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"e0", "=", 
         RowBox[{"UnitVector", "[", 
          RowBox[{"n", ",", "index"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"rows", "=", 
         RowBox[{"NestList", "[", 
          RowBox[{"rowDerivative", ",", "e0", ",", "n"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"Solve", " ", "row4"}], "=", 
          RowBox[{
           RowBox[{"c0", " ", "row0"}], "+", 
           RowBox[{"c1", " ", "row1"}], "+", 
           RowBox[{"c2", " ", "row2"}], "+", 
