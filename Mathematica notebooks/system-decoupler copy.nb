        RowBox[{"R", "=", 
         RowBox[{"rows", "[", 
          RowBox[{"[", 
           RowBox[{"1", ";;", "n"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"b", "=", 
         RowBox[{"rows", "[", 
          RowBox[{"[", 
           RowBox[{"n", "+", "1"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"coeffs", "=", 
         RowBox[{"LinearSolve", "[", 
          RowBox[{
           RowBox[{"Transpose", "[", "R", "]"}], ",", "b"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"target", "=", 
         RowBox[{"vars", "[", 
          RowBox[{"[", "index", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"ode", "=", 
         RowBox[{
          RowBox[{"Together", "[", 
           RowBox[{
            RowBox[{"D", "[", 
             RowBox[{"target", ",", 
              RowBox[{"{", 
               RowBox[{"x", ",", "n"}], "}"}]}], "]"}], "-", 
            RowBox[{"Sum", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"coeffs", "[", 
                RowBox[{"[", "j", "]"}], "]"}], " ", 
               RowBox[{"D", "[", 
                RowBox[{"target", ",", 
                 RowBox[{"{", 
                  RowBox[{"x", ",", 
                   RowBox[{"j", "-", "1"}]}], "}"}]}], "]"}]}], ",", 
              RowBox[{"{", 
               RowBox[{"j", ",", "1", ",", "n"}], "}"}]}], "]"}]}], "]"}], "==",
           "0"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<Rows\>\"", "->", "rows"}], ",", 
          RowBox[{"\"\<Coefficients\>\"", "->", "coeffs"}], ",", 
          RowBox[{"\"\<ODE\>\"", "->", "ode"}]}], "|>"}]}]}], "]"}]}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"odeZ1", "=", 
