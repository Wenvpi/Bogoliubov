     "===", "===", "===", "===", "===", "===", "===", "===", "==="}], "*)"}], 
  
  RowBox[{
   RowBox[{
    RowBox[{"Clear", "[", 
     RowBox[{
     "x", ",", "lam", ",", "z1", ",", "z2", ",", "p1", ",", "p2", ",", "vars",
       ",", "M", ",", "rowDerivative", ",", "decoupleComponent", ",", "odeZ1",
       ",", "lhsZ1", ",", "coeffsZ1", ",", "expectedCoeffsZ1", ",", 
      "coeffCheckZ1", ",", "knownZ1ODE", ",", "derivedZ1Monic", ",", 
      "knownZ1Monic", ",", "zeroCheckZ1"}], "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"vars", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"z1", "[", "x", "]"}], ",", 
       RowBox[{"z2", "[", "x", "]"}], ",", 
       RowBox[{"p1", "[", "x", "]"}], ",", 
       RowBox[{"p2", "[", "x", "]"}]}], "}"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"M", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", 
         RowBox[{"I", " ", 
          RowBox[{"lam", "/", 
           RowBox[{"(", 
            RowBox[{"2", " ", 
             RowBox[{"x", "^", "2"}]}], ")"}]}], " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"I", " ", "x"}], "-", "1"}], ")"}]}], ",", 
         RowBox[{"I", " ", 
          RowBox[{"lam", "/", 
           RowBox[{"(", 
            RowBox[{"2", " ", 
             RowBox[{"x", "^", "2"}]}], ")"}]}], " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"I", " ", "x"}], "+", "1"}], ")"}], " ", 
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{"-", "2"}], " ", "I", " ", "x"}], "]"}]}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", 
         RowBox[{"I", " ", 
          RowBox[{"lam", "/", 
           RowBox[{"(", 
            RowBox[{"2", " ", 
             RowBox[{"x", "^", "2"}]}], ")"}]}], " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"I", " ", "x"}], "-", "1"}], ")"}], " ", 
          RowBox[{"Exp", "[", 
           RowBox[{"2", " ", "I", " ", "x"}], "]"}]}], ",", 
