Cell[CellGroupData[{

Cell["6. Direct verification of the original first-order system", "Section",ExpressionUUID->"b486364f-f8ff-4a66-be7b-cb55a9a9cbb6"],

Cell["\<\
The reconstructed functions satisfy three equations identically. The \
remaining zeta2 equation is proportional to the fourth-order zeta1 equation, \
so it vanishes whenever y solves the zeta1 ODE.\
\>", "Text",ExpressionUUID->"a69b3ce3-a1d2-47b9-ade5-3f383748389b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "y", "]"}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"z1", " ", "=", " ", 
   RowBox[{"y", "[", "x", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"z2rec", " ", "=", " ", 
   RowBox[{"zeta2From", "[", "z1", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"p1rec", " ", "=", " ", 
   RowBox[{"psi1From", "[", "z1", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"p2rec", " ", "=", " ", 
    RowBox[{"psi2From", "[", "z1", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"resZeta1", " ", "=", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{"z1", ",", " ", "x"}], "]"}], " ", "-", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"coefA", " ", "p1rec"}], " ", "+", " ", 
        RowBox[{"coefB", " ", "p2rec"}]}], ")"}]}], ",", " ", 
     RowBox[{"Assumptions", " ", "->", " ", "$Assumptions"}]}], "]"}]}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{"resPsi1", " ", "=", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{"p1rec", ",", " ", "x"}], "]"}], " ", "-", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"coefE", " ", "z1"}], " ", "+", " ", 
        RowBox[{"coefF", " ", "z2rec"}]}], ")"}]}], ",", " ", 
     RowBox[{"Assumptions", " ", "->", " ", "$Assumptions"}]}], "]"}]}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{"resPsi2", " ", "=", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{"p2rec", ",", " ", "x"}], "]"}], " ", "-", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"coefG", " ", "z1"}], " ", "+", " ", 
        RowBox[{"coefH", " ", "z2rec"}]}], ")"}]}], ",", " ", 
     RowBox[{"Assumptions", " ", "->", " ", "$Assumptions"}]}], "]"}]}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{"resZeta2", " ", "=", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{"z2rec", ",", " ", "x"}], "]"}], " ", "-", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"coefC", " ", "p1rec"}], " ", "+", " ", 
        RowBox[{"coefD", " ", "p2rec"}]}], ")"}]}], ",", " ", 
     RowBox[{"Assumptions", " ", "->", " ", "$Assumptions"}]}], "]"}]}], 
  "\n"}], "\n", 
 RowBox[{"zeta2ResidualCheck", " ", "=", " ", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{
    RowBox[{"resZeta2", " ", "+", " ", 
     RowBox[{"2", " ", "I", " ", 
      RowBox[{"Exp", "[", 
       RowBox[{"2", " ", "I", " ", "x"}], "]"}], " ", 
      RowBox[{
       RowBox[{"odeZeta1", "[", "z1", "]"}], "/", 
       RowBox[{"lam", "^", "2"}]}]}]}], ",", " ", 
    RowBox[{"Assumptions", " ", "->", " ", "$Assumptions"}]}], 
   "]"}]}]}], "Input",
 CellLabel->"In[44]:=",ExpressionUUID->"86ee285e-4751-48c6-9124-b8fdd31dc480"],

