     RowBox[{"FrameLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<N(k) = Log[k/k0]\>\"", 
        ",", "\"\<\\!\\(\\*SubscriptBox[\\(\[CapitalDelta]\\), \\(\[Zeta]\\)]\
\\)(k)\>\""}], "}"}]}], ",", 
     RowBox[{"PlotLabel", "->", 
      RowBox[{"Row", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<Sharp-turn approximation,  \>\"", 
         ",", "\"\<\[Lambda]0 = \>\"", ",", "lambda0Value", 
         ",", "\"\<,  \[CapitalDelta]N = \>\"", ",", "DeltaNValue"}], "}"}], 
       "]"}]}], ",", 
     RowBox[{"ImageSize", "->", "Large"}]}], "]"}]}]}]], "Input",
