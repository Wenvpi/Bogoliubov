             RowBox[{"k", "/", "H"}], ")"}], "*", 
            RowBox[{"Exp", "[", 
             RowBox[{"-", "N1"}], "]"}]}]}]}], ")"}]}], ")"}], "==", "Vin2"}],
      "]"}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"solC1", "=", 
   RowBox[{
    RowBox[{"Solve", "[", 
     RowBox[{"eqs1", ",", "cvec1"}], "]"}], "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"solC2", "=", 
   RowBox[{
    RowBox[{"Solve", "[", 
     RowBox[{"eqs2", ",", "cvec2"}], "]"}], "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.988814066860239*^9, 3.9888140871156178`*^9}, {
