   RowBox[{"{", 
    RowBox[{"c11", ",", "c12", ",", "c13", ",", "c14"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"cvec2", "=", 
    RowBox[{"{", 
     RowBox[{"c21", ",", "c22", ",", "c23", ",", "c24"}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
