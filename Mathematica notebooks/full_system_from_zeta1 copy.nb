   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "==="}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Clear", "[", 
     RowBox[{
     "Vout1SharpNumeric", ",", "Vout2SharpNumeric", ",", 
      "DeltaZetaSharpNumeric", ",", "Nk", ",", "NkMin", ",", "NkMax", ",", 
      "nPts", ",", "NkValues", ",", "sharpData"}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"PRL", "/", "document"}], " ", "horizontal", " ", 
      RowBox[{"variable", ":", "Nk"}]}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{"Log", "[", 
        RowBox[{"k", "/", "k0"}], "]"}], " ", "so", " ", "k"}], "=", 
      RowBox[{"k0", " ", 
       RowBox[{
        RowBox[{"Exp", "[", "Nk", "]"}], "."}]}]}]}], "*)"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Vout1SharpNumeric", "[", 
      RowBox[{
       RowBox[{"lambda0Value_", "?", "NumericQ"}], ",", 
       RowBox[{"DeltaNValue_", "?", "NumericQ"}], ",", 
       RowBox[{"NkValue_", "?", "NumericQ"}]}], "]"}], ":=", 
     RowBox[{"N", "[", 
      RowBox[{"Vout1SharpPhysical", "/.", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"lambda0", "->", "lambda0Value"}], ",", 
         RowBox[{"DeltaN", "->", "DeltaNValue"}], ",", 
         RowBox[{"k0", "->", "1"}], ",", 
         RowBox[{"k", "->", 
          RowBox[{"Exp", "[", "NkValue", "]"}]}]}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Vout2SharpNumeric", "[", 
      RowBox[{
       RowBox[{"lambda0Value_", "?", "NumericQ"}], ",", 
       RowBox[{"DeltaNValue_", "?", "NumericQ"}], ",", 
       RowBox[{"NkValue_", "?", "NumericQ"}]}], "]"}], ":=", 
     RowBox[{"N", "[", 
      RowBox[{"Vout2SharpPhysical", "/.", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"lambda0", "->", "lambda0Value"}], ",", 
         RowBox[{"DeltaN", "->", "DeltaNValue"}], ",", 
         RowBox[{"k0", "->", "1"}], ",", 
         RowBox[{"k", "->", 
          RowBox[{"Exp", "[", "NkValue", "]"}]}]}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"DeltaZetaSharpNumeric", "[", 
      RowBox[{
       RowBox[{"lambda0Value_", "?", "NumericQ"}], ",", 
       RowBox[{"DeltaNValue_", "?", "NumericQ"}], ",", 
       RowBox[{"NkValue_", "?", "NumericQ"}]}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"v1", ",", "v2"}], "}"}], ",", 
       RowBox[{
        RowBox[{"v1", "=", 
         RowBox[{"Vout1SharpNumeric", "[", 
          RowBox[{"lambda0Value", ",", "DeltaNValue", ",", "NkValue"}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"v2", "=", 
         RowBox[{"Vout2SharpNumeric", "[", 
          RowBox[{"lambda0Value", ",", "DeltaNValue", ",", "NkValue"}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Re", "[", 
         RowBox[{"Chop", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{
              RowBox[{"v1", "[", 
               RowBox[{"[", "1", "]"}], "]"}], "+", 
              RowBox[{"v1", "[", 
               RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "^", "2"}], "+", 
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{
              RowBox[{"v2", "[", 
               RowBox[{"[", "1", "]"}], "]"}], "+", 
              RowBox[{"v2", "[", 
               RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "^", "2"}]}], "]"}], 
         "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Example", " ", "values", " ", "close", " ", "to", " ", "the", " ", 
      "sharp"}], "-", 
     RowBox[{"turn", " ", "regime"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"lambda0Value", "=", "23"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"DeltaNValue", "=", "1"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"NkMin", "=", 
     RowBox[{"-", "2"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"NkMax", "=", "7"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"nPts", "=", "1000"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"NkValues", "=", 
     RowBox[{"Subdivide", "[", 
      RowBox[{"NkMin", ",", "NkMax", ",", 
       RowBox[{"nPts", "-", "1"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"sharpData", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"NkValue", ",", 
         RowBox[{"DeltaZetaSharpNumeric", "[", 
          RowBox[{"lambda0Value", ",", "DeltaNValue", ",", "NkValue"}], 
          "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"NkValue", ",", "NkValues"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"ListLinePlot", "[", 
    RowBox[{"sharpData", ",", 
     RowBox[{"Frame", "->", "True"}], ",", 
     RowBox[{"Joined", "->", "True"}], ",", 
     RowBox[{"PlotRange", "->", "All"}], ",", 
     RowBox[{"ScalingFunctions", "->", 
