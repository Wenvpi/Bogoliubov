Cell[CellGroupData[{
Cell["Reconstruct zeta2, psi1, psi2 from zeta1", "Title",ExpressionUUID->"7534c523-ffd9-4617-a447-70f7a5b11823"],

Cell["\<\
Given any solution y(x)=zeta1(x) of the fourth-order zeta1 ODE, this notebook \
derives zeta2, psi1, and psi2 directly from y and its derivatives. The \
important part is the algebraic elimination in Sections 3 and 4.\
\>", "Text",ExpressionUUID->"e51e0e0b-eab8-426d-b42c-e29901a7210c"],

Cell[CellGroupData[{

Cell["1. Setup", "Section",ExpressionUUID->"6d7ab782-84df-4661-ade5-a09063fd9dce"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"$Assumptions", " ", "=", " ", 
    RowBox[{
     RowBox[{"Element", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", ",", " ", "lam"}], "}"}], ",", " ", "Reals"}], "]"}], 
     " ", "&&", " ", 
     RowBox[{"x", " ", ">", " ", "0"}], " ", "&&", " ", 
     RowBox[{"lam", " ", ">", " ", "0"}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"odeZeta1", "[", "y_", "]"}], " ", ":=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"x", "^", "2"}], " ", 
      RowBox[{"D", "[", 
       RowBox[{"y", ",", " ", 
        RowBox[{"{", 
         RowBox[{"x", ",", " ", "4"}], "}"}]}], "]"}]}], " ", "+", " ", 
     RowBox[{"4", " ", "x", " ", 
      RowBox[{"(", 
       RowBox[{"1", " ", "+", " ", 
        RowBox[{"I", " ", "x"}]}], ")"}], " ", 
      RowBox[{"D", "[", 
       RowBox[{"y", ",", " ", 
        RowBox[{"{", 
         RowBox[{"x", ",", " ", "3"}], "}"}]}], "]"}]}], " ", "+", "\n", 
     "   ", 
     RowBox[{"2", " ", "x", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"5", " ", "I"}], " ", "-", " ", 
        RowBox[{"2", " ", "x"}]}], ")"}], " ", 
      RowBox[{"D", "[", 
       RowBox[{"y", ",", " ", 
        RowBox[{"{", 
         RowBox[{"x", ",", " ", "2"}], "}"}]}], "]"}]}], " ", "-", " ", 
     RowBox[{"2", " ", 
      RowBox[{"(", 
       RowBox[{"I", " ", "+", " ", 
        RowBox[{"2", " ", "x"}]}], ")"}], " ", 
      RowBox[{"D", "[", 
       RowBox[{"y", ",", " ", "x"}], "]"}]}], " ", "-", " ", 
     RowBox[{
      RowBox[{"lam", "^", "2"}], " ", "y"}]}]}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"Coefficients", " ", "of", " ", "the", " ", "first"}], "-", 
     RowBox[{"order", " ", 
      RowBox[{"system", ":", "\n", "   ", 
       RowBox[{"zeta1", "'"}]}]}]}], " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"A", " ", "psi1"}], " ", "+", " ", 
      RowBox[{"B", " ", "psi2", "\n", "   ", 
       RowBox[{"zeta2", "'"}]}]}], " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"C", " ", "psi1"}], " ", "+", " ", 
       RowBox[{"D", " ", "psi2", "\n", "   ", 
        RowBox[{"psi1", "'"}]}]}], "  ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"E", " ", "zeta1"}], " ", "+", " ", 
        RowBox[{"F", " ", "zeta2", "\n", "   ", 
         RowBox[{"psi2", "'"}]}]}], "  ", "=", " ", 
       RowBox[{
        RowBox[{"G", " ", "zeta1"}], " ", "+", " ", 
        RowBox[{"H", " ", "zeta2"}]}]}]}]}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"coefA", " ", "=", " ", 
   RowBox[{"I", " ", 
    RowBox[{"lam", "/", 
     RowBox[{"(", 
      RowBox[{"2", " ", 
       RowBox[{"x", "^", "2"}]}], ")"}]}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"I", " ", "x"}], " ", "-", " ", "1"}], ")"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"coefB", " ", "=", " ", 
   RowBox[{"I", " ", 
    RowBox[{"lam", "/", 
     RowBox[{"(", 
      RowBox[{"2", " ", 
       RowBox[{"x", "^", "2"}]}], ")"}]}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"I", " ", "x"}], " ", "+", " ", "1"}], ")"}], " ", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", "2"}], " ", "I", " ", "x"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"coefC", " ", "=", " ", 
   RowBox[{"I", " ", 
    RowBox[{"lam", "/", 
     RowBox[{"(", 
      RowBox[{"2", " ", 
       RowBox[{"x", "^", "2"}]}], ")"}]}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"I", " ", "x"}], " ", "-", " ", "1"}], ")"}], " ", 
    RowBox[{"Exp", "[", 
     RowBox[{"2", " ", "I", " ", "x"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"coefD", " ", "=", " ", 
   RowBox[{"I", " ", 
    RowBox[{"lam", "/", 
     RowBox[{"(", 
      RowBox[{"2", " ", 
       RowBox[{"x", "^", "2"}]}], ")"}]}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"I", " ", "x"}], " ", "+", " ", "1"}], ")"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"coefE", " ", "=", " ", 
   RowBox[{"I", " ", 
    RowBox[{"lam", "/", 
     RowBox[{"(", 
      RowBox[{"2", " ", 
       RowBox[{"x", "^", "2"}]}], ")"}]}], " ", 
    RowBox[{"(", 
     RowBox[{"-", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"I", " ", "x"}], " ", "+", " ", "1"}], ")"}]}], ")"}]}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"coefF", " ", "=", " ", 
   RowBox[{"I", " ", 
    RowBox[{"lam", "/", 
     RowBox[{"(", 
      RowBox[{"2", " ", 
       RowBox[{"x", "^", "2"}]}], ")"}]}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"I", " ", "x"}], " ", "+", " ", "1"}], ")"}], " ", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", "2"}], " ", "I", " ", "x"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"coefG", " ", "=", " ", 
   RowBox[{"I", " ", 
    RowBox[{"lam", "/", 
     RowBox[{"(", 
      RowBox[{"2", " ", 
       RowBox[{"x", "^", "2"}]}], ")"}]}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"I", " ", "x"}], " ", "-", " ", "1"}], ")"}], " ", 
    RowBox[{"Exp", "[", 
     RowBox[{"2", " ", "I", " ", "x"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"coefH", " ", "=", " ", 
   RowBox[{"I", " ", 
    RowBox[{"lam", "/", 
     RowBox[{"(", 
      RowBox[{"2", " ", 
       RowBox[{"x", "^", "2"}]}], ")"}]}], " ", 
    RowBox[{"(", 
     RowBox[{"-", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"I", " ", "x"}], " ", "-", " ", "1"}], ")"}]}], ")"}]}]}], 
  ";"}]}], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"7c463a50-76f4-4f4d-99cb-42abe36bd94f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["2. Final reconstruction map", "Section",ExpressionUUID->"6e48f739-7d35-476b-b27a-4bd3fad94b8a"],

Cell["\<\
These are the formulas we want to derive. The next sections show how they are \
obtained from the first-order system.\
\>", "Text",ExpressionUUID->"fd4def29-9dbd-4c7a-8ed9-d81ec02d3f5d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"psi1From", "[", "y_", "]"}], " ", ":=", " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"I", " ", 
           RowBox[{"x", "^", "2"}]}], " ", "+", " ", "x"}], ")"}], " ", 
        RowBox[{"D", "[", 
         RowBox[{"y", ",", " ", 
          RowBox[{"{", 
           RowBox[{"x", ",", " ", "2"}], "}"}]}], "]"}]}], " ", "+", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"-", "2"}], " ", 
           RowBox[{"x", "^", "2"}]}], " ", "+", " ", 
          RowBox[{"3", " ", "I", " ", "x"}], " ", "+", " ", "2"}], ")"}], " ", 
        RowBox[{"D", "[", 
         RowBox[{"y", ",", " ", "x"}], "]"}]}]}], ")"}], "/", 
     RowBox[{"(", 
      RowBox[{"lam", " ", "x"}], ")"}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"psi2From", "[", "y_", "]"}], " ", ":=", " ", 
    RowBox[{
     RowBox[{"-", "I"}], " ", 
     RowBox[{"Exp", "[", 
      RowBox[{"2", " ", "I", " ", "x"}], "]"}], " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"x", "^", "2"}], " ", "+", " ", 
           RowBox[{"I", " ", "x"}]}], ")"}], " ", 
         RowBox[{"D", "[", 
          RowBox[{"y", ",", " ", 
           RowBox[{"{", 
            RowBox[{"x", ",", " ", "2"}], "}"}]}], "]"}]}], " ", "+", " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"x", " ", "+", " ", 
           RowBox[{"2", " ", "I"}]}], ")"}], " ", 
         RowBox[{"D", "[", 
          RowBox[{"y", ",", " ", "x"}], "]"}]}]}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"lam", " ", "x"}], ")"}]}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"zeta2From", "[", "y_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"Exp", "[", 
     RowBox[{"2", " ", "I", " ", "x"}], "]"}], " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"lam", "^", "2"}], " ", "y"}], " ", "-", " ", 
       RowBox[{"2", " ", "I", " ", 
        RowBox[{"x", "^", "2"}], " ", 
        RowBox[{"D", "[", 
         RowBox[{"y", ",", " ", 
          RowBox[{"{", 
           RowBox[{"x", ",", " ", "3"}], "}"}]}], "]"}]}], " ", "+", "\n", 
       "      ", 
       RowBox[{"4", " ", "x", " ", 
        RowBox[{"(", 
         RowBox[{"x", " ", "-", " ", "I"}], ")"}], " ", 
        RowBox[{"D", "[", 
         RowBox[{"y", ",", " ", 
          RowBox[{"{", 
           RowBox[{"x", ",", " ", "2"}], "}"}]}], "]"}]}], " ", "+", " ", 
       RowBox[{"4", " ", 
        RowBox[{"(", 
         RowBox[{"x", " ", "+", " ", "I"}], ")"}], " ", 
        RowBox[{"D", "[", 
         RowBox[{"y", ",", " ", "x"}], "]"}]}]}], ")"}], "/", 
     RowBox[{"lam", "^", "2"}]}]}]}], ";"}]}], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"7a47dd83-d37a-412a-91e6-0373e4842f28"]
}, Open  ]],

Cell[CellGroupData[{

Cell["3. Algebraic derivation, step 1: differentiate zeta1 once", "Section",ExpressionUUID->"ad6581c7-3b4f-439b-b383-fe8083ed303c"],

Cell["\<\
Set y0=y, y1=y', y2=y'', y3=y'''. We treat psi1, psi2, zeta2 as algebraic \
unknowns p1, p2, z2. The total derivative Dx uses the first-order system \
whenever p1, p2, or z2 are differentiated.\
\>", "Text",ExpressionUUID->"85dcb7ea-00b2-433f-a386-c3fdf24ce5ff"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{
    "y0", ",", " ", "y1", ",", " ", "y2", ",", " ", "y3", ",", " ", "y4", ",",
      " ", "p1", ",", " ", "p2", ",", " ", "z2"}], "]"}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"p1Prime", " ", "=", " ", 
   RowBox[{
    RowBox[{"coefE", " ", "y0"}], " ", "+", " ", 
    RowBox[{"coefF", " ", "z2"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"p2Prime", " ", "=", " ", 
   RowBox[{
    RowBox[{"coefG", " ", "y0"}], " ", "+", " ", 
    RowBox[{"coefH", " ", "z2"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"z2Prime", " ", "=", " ", 
    RowBox[{
     RowBox[{"coefC", " ", "p1"}], " ", "+", " ", 
     RowBox[{"coefD", " ", "p2"}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Dx", "[", "expr_", "]"}], " ", ":=", " ", 
    RowBox[{
     RowBox[{"D", "[", 
      RowBox[{"expr", ",", " ", "x"}], "]"}], " ", "+", " ", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{"expr", ",", " ", "y0"}], "]"}], " ", "y1"}], " ", "+", " ", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{"expr", ",", " ", "y1"}], "]"}], " ", "y2"}], " ", "+", "\n", 
     "   ", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{"expr", ",", " ", "y2"}], "]"}], " ", "y3"}], " ", "+", " ", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{"expr", ",", " ", "y3"}], "]"}], " ", "y4"}], " ", "+", "\n", 
     "   ", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{"expr", ",", " ", "p1"}], "]"}], " ", "p1Prime"}], " ", "+", 
     " ", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{"expr", ",", " ", "p2"}], "]"}], " ", "p2Prime"}], " ", "+", 
     " ", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{"expr", ",", " ", "z2"}], "]"}], " ", "z2Prime"}]}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{"rhs1", " ", "=", " ", 
   RowBox[{
    RowBox[{"coefA", " ", "p1"}], " ", "+", " ", 
    RowBox[{"coefB", " ", "p2"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"eqFirst", " ", "=", " ", 
    RowBox[{"y1", " ", "==", " ", "rhs1"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"rhs2", " ", "=", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"Dx", "[", "rhs1", "]"}], ",", " ", 
     RowBox[{"Assumptions", " ", "->", " ", "$Assumptions"}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"eqSecond", " ", "=", " ", 
    RowBox[{"y2", " ", "==", " ", "rhs2"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"{", 
   RowBox[{"eqFirst", ",", " ", "eqSecond"}], "}"}], " ", "//", " ", 
  "TraditionalForm"}]}], "Input",
 CellLabel->"In[15]:=",ExpressionUUID->"d055a37d-e754-45e8-b20c-82335f93701e"],

Cell[BoxData[
 FormBox[
  RowBox[{"{", 
   RowBox[{
    RowBox[{"y1", "\[LongEqual]", 
     RowBox[{
      FractionBox[
       RowBox[{"\[ImaginaryI]", " ", "lam", " ", "p1", " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "1"}], "+", 
          RowBox[{"\[ImaginaryI]", " ", "x"}]}], ")"}]}], 
       RowBox[{"2", " ", 
        SuperscriptBox["x", "2"]}]], "+", 
      FractionBox[
       RowBox[{"\[ImaginaryI]", " ", "lam", " ", "p2", " ", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          RowBox[{"-", "2"}], " ", "\[ImaginaryI]", " ", "x"}]], " ", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"\[ImaginaryI]", " ", "x"}]}], ")"}]}], 
       RowBox[{"2", " ", 
        SuperscriptBox["x", "2"]}]]}]}], ",", 
    RowBox[{"y2", "\[LongEqual]", 
     FractionBox[
      RowBox[{"lam", " ", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"-", "2"}], " ", "\[ImaginaryI]", " ", "x"}]], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"p1", " ", 
          SuperscriptBox["\[ExponentialE]", 
           RowBox[{"2", " ", "\[ImaginaryI]", " ", "x"}]], " ", 
          RowBox[{"(", 
           RowBox[{"x", "+", 
            RowBox[{"2", " ", "\[ImaginaryI]"}]}], ")"}]}], "+", 
         RowBox[{"p2", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"3", "+", 
               RowBox[{"2", " ", "\[ImaginaryI]", " ", "x"}]}], ")"}], " ", 
             "x"}], "-", 
            RowBox[{"2", " ", "\[ImaginaryI]"}]}], ")"}]}]}], ")"}]}], 
      RowBox[{"2", " ", 
       SuperscriptBox["x", "3"]}]]}]}], "}"}], TraditionalForm]], "Output",
 CellChangeTimes->{3.988729482494326*^9, 3.988730848729785*^9},
 CellLabel->
  "Out[24]//TraditionalForm=",ExpressionUUID->"ceaf96fc-cd9d-406d-bbfc-\
9d00e6f11cc0"]
}, Open  ]],

Cell["\<\
A useful cancellation happens: after differentiating zeta1', the expression \
for y'' contains only psi1 and psi2, not zeta2. That is why the first two \
equations can solve for psi1 and psi2.\
\>", "Text",ExpressionUUID->"489da9d2-ef19-48d8-904f-7b791b6f68a9"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"zeta2CoefficientInSecondDerivative", " ", "=", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"Coefficient", "[", 
      RowBox[{
       RowBox[{"Together", "[", "rhs2", "]"}], ",", " ", "z2"}], "]"}], ",", 
     " ", 
     RowBox[{"Assumptions", " ", "->", " ", "$Assumptions"}]}], "]"}]}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{"psiSolutions", " ", "=", " ", 
   RowBox[{
    RowBox[{"Solve", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"eqFirst", ",", " ", "eqSecond"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"p1", ",", " ", "p2"}], "}"}]}], "]"}], " ", "//", " ", 
    "FullSimplify"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"psiSolutions", " ", "//", " ", "TraditionalForm"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"p1Formula", " ", "=", " ", 
   RowBox[{"p1", " ", "/.", " ", 
    RowBox[{"First", "[", "psiSolutions", "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"p2Formula", " ", "=", " ", 
    RowBox[{"p2", " ", "/.", " ", 
     RowBox[{"First", "[", "psiSolutions", "]"}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"{", 
   RowBox[{"p1Formula", ",", " ", "p2Formula"}], "}"}], " ", "//", " ", 
  "TraditionalForm"}]}], "Input",
 CellLabel->"In[25]:=",ExpressionUUID->"ba83c90d-4ab7-48b6-abbb-0c7a06ac4249"],

Cell[BoxData["0"], "Output",
 CellChangeTimes->{3.988729493909833*^9, 3.9887308524869127`*^9},
 CellLabel->"Out[25]=",ExpressionUUID->"bb841114-d921-41e3-836f-00bf6cf600fc"],

Cell[BoxData[
 FormBox[
  RowBox[{"{", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"p1", "\[Rule]", 
      FractionBox[
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"2", "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", 
               RowBox[{"2", " ", "x"}]}], "+", 
              RowBox[{"3", " ", "\[ImaginaryI]"}]}], ")"}], " ", "x"}]}], 
          ")"}], " ", "y1"}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{"\[ImaginaryI]", " ", "x"}]}], ")"}], " ", "x", " ", 
         "y2"}]}], 
       RowBox[{"lam", " ", "x"}]]}], ",", 
     RowBox[{"p2", "\[Rule]", 
      FractionBox[
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"2", " ", "\[ImaginaryI]", " ", "x"}]], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"2", "-", 
             RowBox[{"\[ImaginaryI]", " ", "x"}]}], ")"}], " ", "y1"}], "+", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "-", 
             RowBox[{"\[ImaginaryI]", " ", "x"}]}], ")"}], " ", "x", " ", 
           "y2"}]}], ")"}]}], 
       RowBox[{"lam", " ", "x"}]]}]}], "}"}], "}"}], 
  TraditionalForm]], "Output",
 CellChangeTimes->{3.988729493909833*^9, 3.988730852527061*^9},
