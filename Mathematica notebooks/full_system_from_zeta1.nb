 CellLabel->"Out[53]=",ExpressionUUID->"c582b3e1-cc12-4aaf-b21f-d40ef13c4cea"]
}, Open  ]],

Cell["\<\
Expected: resZeta1=0, resPsi1=0, resPsi2=0, and zeta2ResidualCheck=0. \
Equivalently, resZeta2=-(2 I Exp[2 I x]/lam^2) odeZeta1[y[x]].\
\>", "Text",ExpressionUUID->"139e2e06-29d3-46a6-8748-afb63308dbdf"]
}, Open  ]],

Cell[CellGroupData[{

Cell["7. Use with the zeta1 basis", "Section",ExpressionUUID->"57f631d5-8cb0-454e-bbe1-79fcc5c94e3c"],

Cell["\<\
After defining your four zeta1 basis functions, apply the reconstruction map \
to each one.\
\>", "Text",ExpressionUUID->"4b5fd058-772c-491d-8355-9cc5ad2bed79"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"zeta1basis", " ", "=", " ", 
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"I", "*", "lam"}]}], ")"}], 
        RowBox[{"LaguerreL", "[", 
         RowBox[{
          RowBox[{"I", "*", 
           RowBox[{"lam", "/", "2"}]}], ",", 
          RowBox[{
           RowBox[{"-", "2"}], "*", "I", "*", "x"}]}], "]"}]}], "+", 
       RowBox[{"I", "*", "lam", "*", 
        RowBox[{"Hypergeometric1F1", "[", 
         RowBox[{
          RowBox[{"1", "-", 
           RowBox[{"I", "*", 
            RowBox[{"lam", "/", "2"}]}]}], ",", "2", ",", 
          RowBox[{
           RowBox[{"-", "2"}], "*", "I", "*", "x"}]}], "]"}]}]}], ",", " ", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"I", "*", "lam"}]}], ")"}], 
        RowBox[{"LaguerreL", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"-", "I"}], "*", 
           RowBox[{"lam", "/", "2"}]}], ",", 
          RowBox[{
           RowBox[{"-", "2"}], "*", "I", "*", "x"}]}], "]"}]}], "-", 
       RowBox[{"I", "*", "lam", "*", 
        RowBox[{"Hypergeometric1F1", "[", 
         RowBox[{
          RowBox[{"1", "+", 
           RowBox[{"I", "*", 
            RowBox[{"lam", "/", "2"}]}]}], ",", "2", ",", 
          RowBox[{
           RowBox[{"-", "2"}], "*", "I", "*", "x"}]}], "]"}]}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"I", "*", "lam"}]}], ")"}], 
        RowBox[{"HypergeometricU", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"-", "I"}], "*", 
           RowBox[{"lam", "/", "2"}]}], ",", "1", ",", 
          RowBox[{
           RowBox[{"-", "2"}], "*", "I", "*", "x"}]}], "]"}]}], "-", 
       RowBox[{"I", "*", "lam", "*", 
        RowBox[{"HypergeometricU", "[", 
         RowBox[{
          RowBox[{"1", "-", 
           RowBox[{"I", "*", 
            RowBox[{"lam", "/", "2"}]}]}], ",", "2", ",", 
          RowBox[{
           RowBox[{"-", "2"}], "*", "I", "*", "x"}]}], "]"}]}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"I", "*", "lam"}]}], ")"}], 
        RowBox[{"HypergeometricU", "[", 
         RowBox[{
          RowBox[{"I", "*", 
           RowBox[{"lam", "/", "2"}]}], ",", "1", ",", 
          RowBox[{
           RowBox[{"-", "2"}], "*", "I", "*", "x"}]}], "]"}]}], "+", 
       RowBox[{"I", "*", "lam", "*", 
        RowBox[{"HypergeometricU", "[", 
         RowBox[{
          RowBox[{"1", "+", 
           RowBox[{"I", "*", 
