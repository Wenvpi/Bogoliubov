Cell[TextData[{
 "Finally, the out-region solutions, for every ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"0", "<", 
         StyleBox["x", "TI"], "<", 
         SubscriptBox[
          StyleBox["x", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "0 < x < x_2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9c398499-f7cd-4936-be50-3e96d0c17f60"],
 ", would be given by"
}], "Text",
 CellChangeTimes->{{3.988814205471998*^9, 
  3.98881422863376*^9}},ExpressionUUID->"e4cc3d52-064b-461a-bd4b-\
8ea9e079b029"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Vin1", "=", 
   RowBox[{"{", 
    RowBox[{"1", ",", "0", ",", "0", ",", "0"}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Vin2", "=", 
    RowBox[{"{", 
     RowBox[{"0", ",", "0", ",", "1", ",", "0"}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"cvec1", "=", 
   RowBox[{"{", 
    RowBox[{"c11", ",", "c12", ",", "c13", ",", "c14"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"cvec2", "=", 
    RowBox[{"{", 
     RowBox[{"c21", ",", "c22", ",", "c23", ",", "c24"}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Vout1", "=", 
    RowBox[{"cvec1", ".", 
     RowBox[{"(", 
      RowBox[{"Bmat", "/.", " ", 
       RowBox[{"x", "->", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"k", "/", "H"}], ")"}], "*", 
         RowBox[{"Exp", "[", 
          RowBox[{"-", "N2"}], "]"}]}]}]}], ")"}]}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Vout2", "=", 
   RowBox[{"cvec2", ".", 
    RowBox[{"(", 
     RowBox[{"Bmat", "/.", " ", 
      RowBox[{"x", "->", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"k", "/", "H"}], ")"}], "*", 
        RowBox[{"Exp", "[", 
         RowBox[{"-", "N2"}], "]"}]}]}]}], ")"}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.98881419471701*^9, 3.988814194719199*^9}, {
  3.988814499862238*^9, 3.98881450584374*^9}, {3.9888157645503807`*^9, 
  3.988815793011204*^9}, {3.988871660188987*^9, 3.9888716657467337`*^9}},
 CellLabel->"In[22]:=",ExpressionUUID->"b8388633-25df-4cb3-906d-7363b0c6a52b"],

