    RowBox[{"[", "1", "]"}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.988814066860239*^9, 3.9888140871156178`*^9}},
 CellLabel->"In[19]:=",ExpressionUUID->"6aadd96d-52c4-4abe-aac2-3a71b99c2e9e"],

Cell["where the solutions are horrible, but exist.", "Text",
 CellChangeTimes->{{3.9888141294120703`*^9, 
  3.988814137771345*^9}},ExpressionUUID->"b141ad4d-16cd-46f8-8d89-\
c91281e5ab07"],

Cell["Let\[CloseCurlyQuote]s save these results in advanced,", "Text",
 CellChangeTimes->{{3.988815725669373*^9, 
  3.988815738888973*^9}},ExpressionUUID->"5ba8c37a-2fb3-47df-ba79-\
db3fc630add3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"DumpSave", "[", 
   RowBox[{"\"\<matchingResults.mx\>\"", ",", 
    RowBox[{"{", 
     RowBox[{"solC1", ",", "solC2", ",", "Bmat"}], "}"}]}], "]"}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.988815329975029*^9, 3.9888153341291323`*^9}, 
   3.988815707220442*^9},ExpressionUUID->"e48b4302-6eb3-44dd-b2f5-\
84fa4a93d59a"],

Cell[BoxData[
 TemplateBox[<|"shortenedBoxes" -> TagBox[
     RowBox[{"{", 
       TemplateBox[{"1"}, "OutputSizeLimit`Skeleton"], "}"}], Short[#, 8]& ], 
   "line" -> 28, "sessionID" -> 17035401699200430513, "byteCount" -> 2260352, 
   "size" -> 8, "stored" -> False, "expr" -> 
   Missing["NotAvailable", "NewSessionID"], "wrap" -> OutputSizeLimit`Defer, 
   "version" -> 1|>,
  "OutputSizeLimitTemplate"]], "Output",
 CellChangeTimes->{3.988815338151815*^9},
 CellLabel->"Out[28]=",ExpressionUUID->"307a7fd2-b041-46bb-a9c0-10d45f33913f"]
}, Open  ]],

Cell["and we can recover them directly using", "Text",
 CellChangeTimes->{{3.988815745646299*^9, 
  3.988815755326792*^9}},ExpressionUUID->"59c5204c-bf23-4dd0-9b24-\
409b66b7703a"],

Cell[BoxData[
 RowBox[{"Get", "[", "\"\<matchingResults.mx\>\"", "]"}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"c60ece58-f33b-4daa-8ca2-f4f86477f5ec"],

Cell[TextData[{
 "Finally, the out-region solutions, for every ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"0", "<", 
         StyleBox["x", "TI"], "<", 
         SubscriptBox[
          StyleBox["x", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "0 < x < x_2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9c398499-f7cd-4936-be50-3e96d0c17f60"],
 ", would be given by"
}], "Text",
 CellChangeTimes->{{3.988814205471998*^9, 
  3.98881422863376*^9}},ExpressionUUID->"e4cc3d52-064b-461a-bd4b-\
8ea9e079b029"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Vin1", "=", 
   RowBox[{"{", 
    RowBox[{"1", ",", "0", ",", "0", ",", "0"}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Vin2", "=", 
    RowBox[{"{", 
     RowBox[{"0", ",", "0", ",", "1", ",", "0"}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"cvec1", "=", 
   RowBox[{"{", 
    RowBox[{"c11", ",", "c12", ",", "c13", ",", "c14"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"cvec2", "=", 
    RowBox[{"{", 
     RowBox[{"c21", ",", "c22", ",", "c23", ",", "c24"}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Vout1", "=", 
    RowBox[{"cvec1", ".", 
     RowBox[{"(", 
      RowBox[{"Bmat", "/.", " ", 
       RowBox[{"x", "->", "x2"}]}], ")"}]}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"Vout2", "=", 
   RowBox[{"cvec2", ".", 
    RowBox[{"(", 
     RowBox[{"Bmat", "/.", " ", 
      RowBox[{"x", "->", "x2"}]}], ")"}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.98881419471701*^9, 3.988814194719199*^9}, {
  3.988814499862238*^9, 3.98881450584374*^9}, {3.9888157645503807`*^9, 
  3.988815793011204*^9}},
 CellLabel->"In[4]:=",ExpressionUUID->"b8388633-25df-4cb3-906d-7363b0c6a52b"],

Cell["\<\
and replacing with the values we found for the constant vectors\
\>", "Text",
 CellChangeTimes->{{3.9888158094640303`*^9, 
  3.9888158193476057`*^9}},ExpressionUUID->"81dd9ccd-09fc-436f-b59f-\
680af073e755"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Vout1", "=", 
    RowBox[{"Vout1", "/.", " ", "solC1"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Vout2", "=", 
   RowBox[{"Vout2", "/.", " ", "solC2"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.988815824866166*^9, 3.988815828195661*^9}},
 CellLabel->"In[11]:=",ExpressionUUID->"4436a001-2b1d-4d8e-9d33-114f23b2c0de"],

Cell["Saving this too", "Text",
 CellChangeTimes->{{3.9888159808642473`*^9, 
  3.988815984653359*^9}},ExpressionUUID->"ec33a1f1-0517-4708-bb86-\
9593e06a1dcb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"DumpSave", "[", 
   RowBox[{"\"\<matchingResults.mx\>\"", ",", 
    RowBox[{"{", 
     RowBox[{"solC1", ",", "solC2", ",", "Bmat", ",", "Vout1", ",", "Vout2"}],
      "}"}]}], "]"}], ";"}]], "Input",
 CellChangeTimes->{{3.988815929473269*^9, 3.988815930714468*^9}},
 CellLabel->"In[17]:=",ExpressionUUID->"5657f0b5-58d4-42ef-a134-189162f4d5b2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Get", "[", "\"\<matchingResults.mx\>\"", "]"}], ";"}]], "Input",
 CellChangeTimes->{{3.988815955388554*^9, 
  3.988815990453291*^9}},ExpressionUUID->"fed6113a-9e0a-41f3-a8a5-\
8f77d8f69dc2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"N", "[", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"Vout1", "[", 
     RowBox[{"[", "1", "]"}], "]"}], ")"}], "/.", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"x1", "->", "10"}], ",", 
     RowBox[{"x2", "->", "2"}], ",", 
     RowBox[{"lam", "->", "1"}]}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.988815995753765*^9, 3.988816061671883*^9}},
 CellLabel->"In[3]:=",ExpressionUUID->"6335ab5d-0be8-4be1-8fcd-952a96c661c9"],

