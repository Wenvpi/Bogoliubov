       "y2"}]}], 
     RowBox[{"lam", " ", "x"}]], ",", 
    FractionBox[
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"2", " ", "\[ImaginaryI]", " ", "x"}]], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"2", "-", 
           RowBox[{"\[ImaginaryI]", " ", "x"}]}], ")"}], " ", "y1"}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{"\[ImaginaryI]", " ", "x"}]}], ")"}], " ", "x", " ", 
         "y2"}]}], ")"}]}], 
     RowBox[{"lam", " ", "x"}]]}], "}"}], TraditionalForm]], "Output",
 CellChangeTimes->{3.988729493909833*^9, 3.988730852534093*^9},
 CellLabel->
  "Out[30]//TraditionalForm=",ExpressionUUID->"fe2c6efd-d163-4065-aa16-\
618aff317042"]
}, Open  ]],

Cell["Thus psi1 and psi2 are already determined by y' and y''.", "Text",ExpressionUUID->"0124dd1e-1a81-4df0-83d9-6878dba925c2"]
}, Open  ]],

Cell[CellGroupData[{

Cell["4. Algebraic derivation, step 2: differentiate one more time", "Section",ExpressionUUID->"324c880b-f11a-4a20-959d-bdde09dc266b"],

Cell["\<\
Now differentiate y'' once more. This produces y''' and introduces zeta2 \
through psi1' and psi2'. Substituting the psi1 and psi2 formulas leaves one \
algebraic equation for zeta2.\
\>", "Text",ExpressionUUID->"937c1b92-7b16-47e1-bb3d-7d3817f879d1"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"rhs3BeforeSubstitution", " ", "=", " ", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{"Dx", "[", "rhs2", "]"}], ",", " ", 
      RowBox[{"Assumptions", " ", "->", " ", "$Assumptions"}]}], "]"}]}], 
   ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"rhs3", " ", "=", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"rhs3BeforeSubstitution", " ", "/.", " ", 
      RowBox[{"First", "[", "psiSolutions", "]"}]}], ",", " ", 
     RowBox[{"Assumptions", " ", "->", " ", "$Assumptions"}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"eqThird", " ", "=", " ", 
    RowBox[{"y3", " ", "==", " ", "rhs3"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"zeta2Solution", " ", "=", " ", 
   RowBox[{
    RowBox[{"Solve", "[", 
     RowBox[{"eqThird", ",", " ", "z2"}], "]"}], " ", "//", " ", 
    "FullSimplify"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"zeta2Solution", " ", "//", " ", "TraditionalForm"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{"z2Formula", " ", "=", " ", 
   RowBox[{"z2", " ", "/.", " ", 
    RowBox[{"First", "[", "zeta2Solution", "]"}]}]}], ";"}], "\n", 
 RowBox[{"z2Formula", " ", "//", " ", "TraditionalForm"}]}], "Input",
 CellLabel->"In[31]:=",ExpressionUUID->"1173a19f-edf3-4ae5-a719-383860609a2b"],

Cell[BoxData[
 FormBox[
  RowBox[{"{", 
   RowBox[{"{", 
    RowBox[{"z2", "\[Rule]", 
     FractionBox[
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"2", " ", "\[ImaginaryI]", " ", "x"}]], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          SuperscriptBox["lam", "2"], " ", "y0"}], "-", 
         RowBox[{"2", " ", "\[ImaginaryI]", " ", 
          SuperscriptBox["x", "2"], " ", "y3"}], "+", 
         RowBox[{"4", " ", 
          RowBox[{"(", 
           RowBox[{"x", "+", "\[ImaginaryI]"}], ")"}], " ", "y1"}], "+", 
         RowBox[{"4", " ", "x", " ", 
          RowBox[{"(", 
           RowBox[{"x", "-", "\[ImaginaryI]"}], ")"}], " ", "y2"}]}], ")"}]}], 
      SuperscriptBox["lam", "2"]]}], "}"}], "}"}], TraditionalForm]], "Output",\

 CellChangeTimes->{3.988730859882821*^9},
 CellLabel->
  "Out[35]//TraditionalForm=",ExpressionUUID->"6f1b27c4-8190-41b5-8ad0-\
365be3e1339f"],

Cell[BoxData[
 FormBox[
  FractionBox[
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "x"}]], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       SuperscriptBox["lam", "2"], " ", "y0"}], "-", 
      RowBox[{"2", " ", "\[ImaginaryI]", " ", 
       SuperscriptBox["x", "2"], " ", "y3"}], "+", 
      RowBox[{"4", " ", 
       RowBox[{"(", 
        RowBox[{"x", "+", "\[ImaginaryI]"}], ")"}], " ", "y1"}], "+", 
      RowBox[{"4", " ", "x", " ", 
       RowBox[{"(", 
        RowBox[{"x", "-", "\[ImaginaryI]"}], ")"}], " ", "y2"}]}], ")"}]}], 
   SuperscriptBox["lam", "2"]], TraditionalForm]], "Output",
 CellChangeTimes->{3.988730859885211*^9},
 CellLabel->
  "Out[37]//TraditionalForm=",ExpressionUUID->"64e63635-9655-4348-87b6-\
a0e42027f4d1"]
}, Open  ]],

Cell["\<\
This completes the elimination: {y',y''} gives psi1 and psi2, and y''' gives \
zeta2.\
\>", "Text",ExpressionUUID->"7335d62c-10b0-43a8-88e2-9074253cccd8"]
}, Open  ]],

Cell[CellGroupData[{

Cell["5. Convert the algebraic formulas into functions of y(x)", "Section",ExpressionUUID->"255f85a3-f149-4d21-bd27-38e2b6b0ed0f"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"toFunctionRules", " ", "=", " ", 
    RowBox[{"{", "\n", "   ", 
     RowBox[{
      RowBox[{"y0", " ", "->", " ", 
       RowBox[{"y", "[", "x", "]"}]}], ",", "\n", "   ", 
      RowBox[{"y1", " ", "->", " ", 
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"y", "[", "x", "]"}], ",", " ", "x"}], "]"}]}], ",", "\n", 
      "   ", 
      RowBox[{"y2", " ", "->", " ", 
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"y", "[", "x", "]"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"x", ",", " ", "2"}], "}"}]}], "]"}]}], ",", "\n", "   ", 
      RowBox[{"y3", " ", "->", " ", 
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"y", "[", "x", "]"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"x", ",", " ", "3"}], "}"}]}], "]"}]}]}], "\n", "}"}]}], 
   ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"psi1Derived", " ", "=", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"p1Formula", " ", "/.", " ", "toFunctionRules"}], ",", " ", 
     RowBox[{"Assumptions", " ", "->", " ", "$Assumptions"}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"psi2Derived", " ", "=", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"p2Formula", " ", "/.", " ", "toFunctionRules"}], ",", " ", 
     RowBox[{"Assumptions", " ", "->", " ", "$Assumptions"}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"zeta2Derived", " ", "=", " ", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{"z2Formula", " ", "/.", " ", "toFunctionRules"}], ",", " ", 
      RowBox[{"Assumptions", " ", "->", " ", "$Assumptions"}]}], "]"}]}], 
   ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{
    "psi1Derived", ",", " ", "psi2Derived", ",", " ", "zeta2Derived"}], "}"}],
    " ", "//", " ", "TraditionalForm"}], "\n"}], "\n", 
 RowBox[{"checkAgainstDefinitions", " ", "=", " ", 
  RowBox[{"FullSimplify", "[", "\n", "   ", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"psi1Derived", " ", "-", " ", 
       RowBox[{"psi1From", "[", 
        RowBox[{"y", "[", "x", "]"}], "]"}]}], ",", " ", 
      RowBox[{"psi2Derived", " ", "-", " ", 
       RowBox[{"psi2From", "[", 
        RowBox[{"y", "[", "x", "]"}], "]"}]}], ",", " ", 
      RowBox[{"zeta2Derived", " ", "-", " ", 
       RowBox[{"zeta2From", "[", 
        RowBox[{"y", "[", "x", "]"}], "]"}]}]}], "}"}], ",", "\n", "   ", 
    RowBox[{"Assumptions", " ", "->", " ", "$Assumptions"}]}], 
   "]"}]}], "\n"}], "Input",
 CellLabel->"In[38]:=",ExpressionUUID->"09b2db76-1650-40e8-ade0-0ad811328ffc"],

Cell[BoxData[
 FormBox[
  RowBox[{"{", 
   RowBox[{
    FractionBox[
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "+", 
         RowBox[{"\[ImaginaryI]", " ", "x"}]}], ")"}], " ", "x", " ", 
       RowBox[{
        SuperscriptBox["y", "\[Prime]\[Prime]",
         MultilineFunction->None], "(", "x", ")"}]}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"2", "+", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{"2", " ", "x"}]}], "+", 
            RowBox[{"3", " ", "\[ImaginaryI]"}]}], ")"}], " ", "x"}]}], ")"}],
        " ", 
       RowBox[{
        SuperscriptBox["y", "\[Prime]",
         MultilineFunction->None], "(", "x", ")"}]}]}], 
     RowBox[{"lam", " ", "x"}]], ",", 
    FractionBox[
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"2", " ", "\[ImaginaryI]", " ", "x"}]], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{"\[ImaginaryI]", " ", "x"}]}], ")"}], " ", "x", " ", 
         RowBox[{
          SuperscriptBox["y", "\[Prime]\[Prime]",
           MultilineFunction->None], "(", "x", ")"}]}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"2", "-", 
           RowBox[{"\[ImaginaryI]", " ", "x"}]}], ")"}], " ", 
         RowBox[{
          SuperscriptBox["y", "\[Prime]",
           MultilineFunction->None], "(", "x", ")"}]}]}], ")"}]}], 
     RowBox[{"lam", " ", "x"}]], ",", 
    FractionBox[
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"2", " ", "\[ImaginaryI]", " ", "x"}]], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         SuperscriptBox["lam", "2"], " ", 
         RowBox[{"y", "(", "x", ")"}]}], "-", 
        RowBox[{"2", " ", "\[ImaginaryI]", " ", 
         SuperscriptBox["x", "2"], " ", 
         RowBox[{
          SuperscriptBox["y", 
           TagBox[
            RowBox[{"(", "3", ")"}],
            Derivative],
           MultilineFunction->None], "(", "x", ")"}]}], "+", 
        RowBox[{"4", " ", "x", " ", 
         RowBox[{"(", 
          RowBox[{"x", "-", "\[ImaginaryI]"}], ")"}], " ", 
         RowBox[{
          SuperscriptBox["y", "\[Prime]\[Prime]",
           MultilineFunction->None], "(", "x", ")"}]}], "+", 
        RowBox[{"4", " ", 
         RowBox[{"(", 
          RowBox[{"x", "+", "\[ImaginaryI]"}], ")"}], " ", 
         RowBox[{
          SuperscriptBox["y", "\[Prime]",
           MultilineFunction->None], "(", "x", ")"}]}]}], ")"}]}], 
     SuperscriptBox["lam", "2"]]}], "}"}], TraditionalForm]], "Output",
 CellChangeTimes->{3.988730869417959*^9},
 CellLabel->
  "Out[42]//TraditionalForm=",ExpressionUUID->"4afff06d-7939-45ae-9bfd-\
ef71c3f98700"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", "0", ",", "0"}], "}"}]], "Output",
 CellChangeTimes->{3.9887308694187813`*^9},
 CellLabel->"Out[43]=",ExpressionUUID->"164b4e02-ecd8-4baf-a977-75ca436de7c6"]
}, Open  ]],

Cell["Expected: checkAgainstDefinitions = {0,0,0}.", "Text",ExpressionUUID->"9c5f7cca-aa85-47f3-ba60-c6f33f2007a7"]
