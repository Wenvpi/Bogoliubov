 CellLabel->"Out[51]=",ExpressionUUID->"1e03e0d9-82d8-48fd-a614-ea0a6681e112"],

Cell[BoxData[
 FractionBox[
  RowBox[{"2", " ", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"2", " ", "\[ImaginaryI]", " ", "x"}]], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"\[ImaginaryI]", " ", 
      SuperscriptBox["lam", "2"], " ", 
      RowBox[{"y", "[", "x", "]"}]}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "2"}], "+", 
        RowBox[{"4", " ", "\[ImaginaryI]", " ", "x"}]}], ")"}], " ", 
      RowBox[{
       SuperscriptBox["y", "\[Prime]",
        MultilineFunction->None], "[", "x", "]"}]}], "+", 
     RowBox[{"x", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", " ", 
         RowBox[{"(", 
          RowBox[{"5", "+", 
           RowBox[{"2", " ", "\[ImaginaryI]", " ", "x"}]}], ")"}], " ", 
         RowBox[{
          SuperscriptBox["y", "\[Prime]\[Prime]",
           MultilineFunction->None], "[", "x", "]"}]}], "+", 
        RowBox[{"4", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "\[ImaginaryI]"}], "+", "x"}], ")"}], " ", 
         RowBox[{
          SuperscriptBox["y", 
           TagBox[
            RowBox[{"(", "3", ")"}],
            Derivative],
           MultilineFunction->None], "[", "x", "]"}]}], "-", 
        RowBox[{"\[ImaginaryI]", " ", "x", " ", 
         RowBox[{
          SuperscriptBox["y", 
           TagBox[
            RowBox[{"(", "4", ")"}],
            Derivative],
           MultilineFunction->None], "[", "x", "]"}]}]}], ")"}]}]}], ")"}]}], 
  
  SuperscriptBox["lam", "2"]]], "Output",
 CellChangeTimes->{3.9887309036524487`*^9},
 CellLabel->"Out[52]=",ExpressionUUID->"036f4f1f-d828-4fad-be5b-4613918c3103"],

