Cell[TextData[{
 "Using Vout1 and Vou2 we can compute the power spectrum associated to both \
fields ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Zeta]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\zeta", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9e15af12-cc9d-46ea-9944-aafc26f8a6a1"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Psi]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\psi", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "65102c87-d389-409b-8f76-a2fdc146966b"],
 ". The following cell provides a discrete plot of these quantities for \
specific values of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"(", 
         RowBox[{
           SubscriptBox[
            StyleBox["N", "TI"], "1"], ",", 
           SubscriptBox[
            StyleBox["N", "TI"], "2"], ",", "\[Lambda]", ",", 
           StyleBox["H", "TI"], ",", "\[Epsilon]", ",", 
           SubscriptBox[
            StyleBox["M", "TI"], 
            RowBox[{
              StyleBox["P", "TI"], 
              StyleBox["l", "TI"]}]]}], ")"}], TraditionalForm], 
     "errors" -> {}, "input" -> "(N_1,N_2,\\lambda,H,\\epsilon,M_{Pl})", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "386540a0-119b-47cf-b8ae-1744d46c1ca1"]
}], "Text",
 CellChangeTimes->{{3.9888776294373493`*^9, 
  3.988877685833617*^9}},ExpressionUUID->"bfb83d71-ca11-4e98-a540-\
92362d3e8582"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "==="}], "*)"}], 
  
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Power", " ", "spectrum", " ", "from", " ", "rectangular", " ", "feature",
      " ", "in", " ", "e"}], "-", 
    RowBox[{"folds", " ", "N"}]}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"x", 
     RowBox[{"(", 
      RowBox[{"k", ",", "N"}], ")"}]}], "=", 
    RowBox[{
     RowBox[{"Exp", "[", 
      RowBox[{"Nk", "-", "N"}], "]"}], "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"k", "/", "H"}], ")"}], " ", 
      RowBox[{"Exp", "[", 
       RowBox[{"-", "N"}], "]"}]}]}]}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{"No", " ", 
    RowBox[{"Simplify", "/", "FullSimplify"}], " ", "is", " ", "used"}], 
   "*)"}], 
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "==="}], "*)"}], 
  
  RowBox[{
   RowBox[{
    RowBox[{"Clear", "[", 
     RowBox[{
     "xOfKN", ",", "x1OfK", ",", "x2OfK", ",", "lambdaSymbol", ",", "xSymbol",
       ",", "Vin1", ",", "Vin2", ",", "Vout1Numeric", ",", "Vout2Numeric", ",",
       "P0Numeric", ",", "PzetaNumeric", ",", "PpsiNumeric", ",", 
      "kGridLinear", ",", "kGridLog", ",", "pZetaData", ",", "pPsiData", ",", 
      "lamVal", ",", "HVal", ",", "epsVal", ",", "MplVal", ",", "N1Val", ",", 
      "N2Val", ",", "kVal", ",", "wp", ",", "kMin", ",", "kMax", ",", 
      "nPts"}], "]"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Symbols", " ", "used", " ", "inside", " ", "fullSystemBasis"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"lambdaSymbol", "=", "lam"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"xSymbol", "=", "x"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"Your", " ", "basis", " ", "matrix", " ", "with", " ", "row"}], 
      "-", 
      RowBox[{"vector", " ", 
       RowBox[{"convention", ":", 
        RowBox[{
         RowBox[{"V", "^", 
          RowBox[{"(", "i", ")"}]}], 
         RowBox[{"(", "x", ")"}]}]}]}]}], "=", 
     RowBox[{
      RowBox[{"c", "^", 
       RowBox[{"(", "i", ")"}]}], ".", "Bmat"}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Bmat", "=", "fullSystemBasis"}], ";"}], "*)"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Initial", " ", "quantum", " ", "modes"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Vin1", "=", 
     RowBox[{"{", 
      RowBox[{"1", ",", "0", ",", "0", ",", "0"}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Vin2", "=", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", "1", ",", "0"}], "}"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"E", "-", 
     RowBox[{"fold", " ", "expression", " ", "for", " ", "x"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"xOfKN", "[", 
      RowBox[{
       RowBox[{"kval_", "?", "NumericQ"}], ",", 
       RowBox[{"Hval_", "?", "NumericQ"}], ",", 
       RowBox[{"Nval_", "?", "NumericQ"}]}], "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"kval", "/", "Hval"}], ")"}], " ", 
      RowBox[{"Exp", "[", 
       RowBox[{"-", "Nval"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"x1OfK", "[", 
      RowBox[{
       RowBox[{"kval_", "?", "NumericQ"}], ",", 
       RowBox[{"Hval_", "?", "NumericQ"}], ",", 
       RowBox[{"N1val_", "?", "NumericQ"}]}], "]"}], ":=", 
     RowBox[{"xOfKN", "[", 
      RowBox[{"kval", ",", "Hval", ",", "N1val"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"x2OfK", "[", 
      RowBox[{
       RowBox[{"kval_", "?", "NumericQ"}], ",", 
       RowBox[{"Hval_", "?", "NumericQ"}], ",", 
       RowBox[{"N2val_", "?", "NumericQ"}]}], "]"}], ":=", 
     RowBox[{"xOfKN", "[", 
      RowBox[{"kval", ",", "Hval", ",", "N2val"}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Out", "-", 
     RowBox[{
     "region", " ", "Bogoliubov", " ", "vector", " ", "for", " ", "the", " ", 
      "first", " ", "physical", " ", "quantum", " ", "mode"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Vout1Numeric", "[", 
     RowBox[{
      RowBox[{"lamval_", "?", "NumericQ"}], ",", 
      RowBox[{"N1val_", "?", "NumericQ"}], ",", 
      RowBox[{"N2val_", "?", "NumericQ"}], ",", 
      RowBox[{"kval_", "?", "NumericQ"}], ",", 
      RowBox[{"Hval_", "?", "NumericQ"}], ",", 
      RowBox[{"wpval_", ":", "40"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"x1val", ",", "x2val", ",", "B1", ",", "B2", ",", "c1"}], 
       "}"}], ",", 
      RowBox[{
       RowBox[{"x1val", "=", 
        RowBox[{"x1OfK", "[", 
         RowBox[{"kval", ",", "Hval", ",", "N1val"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"x2val", "=", 
        RowBox[{"x2OfK", "[", 
         RowBox[{"kval", ",", "Hval", ",", "N2val"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"B1", "=", 
        RowBox[{"N", "[", 
         RowBox[{
          RowBox[{"Bmat", "/.", " ", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"lambdaSymbol", "->", "lamval"}], ",", 
             RowBox[{"xSymbol", "->", "x1val"}]}], "}"}]}], ",", "wpval"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"B2", "=", 
        RowBox[{"N", "[", 
         RowBox[{
          RowBox[{"Bmat", "/.", " ", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"lambdaSymbol", "->", "lamval"}], ",", 
             RowBox[{"xSymbol", "->", "x2val"}]}], "}"}]}], ",", "wpval"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Row", " ", 
         RowBox[{"convention", ":", 
          RowBox[{
           RowBox[{"c", ".", "B1"}], "==", 
           RowBox[{
            RowBox[{"Vin1", ".", "Mathematica"}], " ", "solves", " ", 
            RowBox[{
             RowBox[{"Transpose", "[", "B1", "]"}], ".", "c"}]}], "==", 
           RowBox[{"Vin1", "."}]}]}]}], "*)"}], 
       RowBox[{"c1", "=", 
        RowBox[{"LinearSolve", "[", 
         RowBox[{
          RowBox[{"Transpose", "[", "B1", "]"}], ",", "Vin1"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Chop", "[", 
        RowBox[{"c1", ".", "B2"}], "]"}]}]}], "]"}]}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Out", "-", 
     RowBox[{
     "region", " ", "Bogoliubov", " ", "vector", " ", "for", " ", "the", " ", 
      "second", " ", "physical", " ", "quantum", " ", "mode"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Vout2Numeric", "[", 
     RowBox[{
      RowBox[{"lamval_", "?", "NumericQ"}], ",", 
      RowBox[{"N1val_", "?", "NumericQ"}], ",", 
      RowBox[{"N2val_", "?", "NumericQ"}], ",", 
      RowBox[{"kval_", "?", "NumericQ"}], ",", 
      RowBox[{"Hval_", "?", "NumericQ"}], ",", 
      RowBox[{"wpval_", ":", "40"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"x1val", ",", "x2val", ",", "B1", ",", "B2", ",", "c2"}], 
       "}"}], ",", 
      RowBox[{
       RowBox[{"x1val", "=", 
        RowBox[{"x1OfK", "[", 
         RowBox[{"kval", ",", "Hval", ",", "N1val"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"x2val", "=", 
        RowBox[{"x2OfK", "[", 
         RowBox[{"kval", ",", "Hval", ",", "N2val"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"B1", "=", 
        RowBox[{"N", "[", 
         RowBox[{
          RowBox[{"Bmat", "/.", " ", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"lambdaSymbol", "->", "lamval"}], ",", 
             RowBox[{"xSymbol", "->", "x1val"}]}], "}"}]}], ",", "wpval"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"B2", "=", 
        RowBox[{"N", "[", 
         RowBox[{
          RowBox[{"Bmat", "/.", " ", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"lambdaSymbol", "->", "lamval"}], ",", 
             RowBox[{"xSymbol", "->", "x2val"}]}], "}"}]}], ",", "wpval"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"c2", "=", 
        RowBox[{"LinearSolve", "[", 
         RowBox[{
          RowBox[{"Transpose", "[", "B1", "]"}], ",", "Vin2"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Chop", "[", 
        RowBox[{"c2", ".", "B2"}], "]"}]}]}], "]"}]}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Slow", "-", 
     RowBox[{"roll", " ", "normalization"}]}], "*)"}], "\[IndentingNewLine]", 
   
   RowBox[{
    RowBox[{
     RowBox[{"P0Numeric", "[", 
      RowBox[{
       RowBox[{"Hval_", "?", "NumericQ"}], ",", 
       RowBox[{"epsval_", "?", "NumericQ"}], ",", 
       RowBox[{"Mplval_", "?", "NumericQ"}]}], "]"}], ":=", 
     RowBox[{
      RowBox[{"Hval", "^", "2"}], "/", 
      RowBox[{"(", 
       RowBox[{"8", " ", 
        RowBox[{"Pi", "^", "2"}], " ", "epsval", " ", 
        RowBox[{"Mplval", "^", "2"}]}], ")"}]}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Curvature", " ", "power", " ", "spectrum"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"PzetaNumeric", "[", 
     RowBox[{
      RowBox[{"lamval_", "?", "NumericQ"}], ",", 
      RowBox[{"N1val_", "?", "NumericQ"}], ",", 
      RowBox[{"N2val_", "?", "NumericQ"}], ",", 
      RowBox[{"kval_", "?", "NumericQ"}], ",", 
      RowBox[{"Hval_", "?", "NumericQ"}], ",", 
