Notebook[{

Cell[CellGroupData[{
Cell["Remaining solutions for zeta1(x)", "Title",ExpressionUUID->"920afbd0-bafc-476b-b9ce-3df6d768fcbb"],

Cell["\<\
This notebook derives and checks a concrete candidate for the two missing \
solutions of the fourth-order zeta1 equation. The key idea is to change \
variables z = -2 I x and use Kummer's equation. The already-known bounded \
solutions come from Hypergeometric1F1; the missing pair comes from the second \
Kummer solution HypergeometricU.\
\>", "Text",ExpressionUUID->"d2ce9612-e11b-47be-a9ea-299a65e21426"],

Cell[CellGroupData[{

Cell["0. Setup", "Section",ExpressionUUID->"135be8eb-b116-4dec-baca-f55800166e21"],

Cell[BoxData[
 RowBox[{"\n", 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"$Assumptions", " ", "=", " ", 
     RowBox[{
      RowBox[{"Element", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"x", ",", " ", "z", ",", " ", "s", ",", " ", "lam"}], "}"}], 
        ",", " ", "Reals"}], "]"}], " ", "&&", " ", 
      RowBox[{"x", " ", ">", " ", "0"}], " ", "&&", " ", 
      RowBox[{"lam", " ", ">", " ", "0"}]}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"odeX", "[", "y_", "]"}], " ", ":=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"x", "^", "2"}], " ", 
       RowBox[{"D", "[", 
        RowBox[{"y", ",", " ", 
         RowBox[{"{", 
          RowBox[{"x", ",", " ", "4"}], "}"}]}], "]"}]}], " ", "+", " ", 
      RowBox[{"4", " ", "x", " ", 
       RowBox[{"(", 
        RowBox[{"1", " ", "+", " ", 
         RowBox[{"I", " ", "x"}]}], ")"}], " ", 
       RowBox[{"D", "[", 
        RowBox[{"y", ",", " ", 
         RowBox[{"{", 
          RowBox[{"x", ",", " ", "3"}], "}"}]}], "]"}]}], " ", "+", "\n", 
      "   ", 
      RowBox[{"2", " ", "x", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"5", " ", "I"}], " ", "-", " ", 
         RowBox[{"2", " ", "x"}]}], ")"}], " ", 
       RowBox[{"D", "[", 
        RowBox[{"y", ",", " ", 
         RowBox[{"{", 
          RowBox[{"x", ",", " ", "2"}], "}"}]}], "]"}]}], " ", "-", " ", 
      RowBox[{"2", " ", 
       RowBox[{"(", 
        RowBox[{"I", " ", "+", " ", 
         RowBox[{"2", " ", "x"}]}], ")"}], " ", 
       RowBox[{"D", "[", 
        RowBox[{"y", ",", " ", "x"}], "]"}]}], " ", "-", " ", 
      RowBox[{
       RowBox[{"lam", "^", "2"}], " ", "y"}]}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"safeSimplify", "[", 
      RowBox[{"expr_", ",", " ", 
       RowBox[{"sec_", ":", " ", "45"}]}], "]"}], " ", ":=", " ", 
     RowBox[{"TimeConstrained", "[", "\n", "   ", 
      RowBox[{
       RowBox[{"FullSimplify", "[", 
        RowBox[{
         RowBox[{"PowerExpand", "[", 
          RowBox[{"FunctionExpand", "[", "expr", "]"}], "]"}], ",", " ", 
         RowBox[{"Assumptions", " ", "->", " ", "$Assumptions"}]}], "]"}], ",",
        "\n", "   ", "sec", ",", "\n", "   ", "expr"}], "\n", "]"}]}], ";"}], 
   "\n"}]}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"096e11db-861a-4e72-957e-951245c3694a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["1. Rewrite the ODE with z = -2 I x", "Section",ExpressionUUID->"6ec525ef-89e7-45fa-8ae4-7bed1f0f69a5"],

Cell["\<\
If y(x)=Y(z) with z=-2 I x, Mathematica checks that the x-equation is \
equivalent to the following z-equation after division by -4.\
\>", "Text",ExpressionUUID->"642164a6-d664-4d10-ad27-36bda0305191"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\n", 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", "Y", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"zRule", " ", "=", " ", 
     RowBox[{"z", " ", "->", " ", 
      RowBox[{
       RowBox[{"-", "2"}], " ", "I", " ", "x"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Yofx", " ", "=", " ", 
     RowBox[{"Y", "[", 
      RowBox[{
       RowBox[{"-", "2"}], " ", "I", " ", "x"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"odeInZRaw", " ", "=", " ", 
     RowBox[{
      RowBox[{"odeX", "[", "Yofx", "]"}], " ", "/.", " ", 
      RowBox[{"x", " ", "->", " ", 
       RowBox[{"I", " ", 
        RowBox[{"z", "/", "2"}]}]}]}]}], ";"}], "\n", 
   RowBox[{"odeInZ", " ", "=", " ", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{"-", "odeInZRaw"}], "/", "4"}], "]"}]}], "\n", "\n", 
   RowBox[{
    RowBox[{"targetZEquation", " ", "=", "\n", "   ", 
     RowBox[{
      RowBox[{
       RowBox[{"z", "^", "2"}], " ", 
       RowBox[{
        RowBox[{
         RowBox[{"Derivative", "[", "4", "]"}], "[", "Y", "]"}], "[", "z", 
        "]"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"4", " ", "z"}], " ", "-", " ", 
         RowBox[{"2", " ", 
          RowBox[{"z", "^", "2"}]}]}], ")"}], " ", 
       RowBox[{
        RowBox[{
         RowBox[{"Derivative", "[", "3", "]"}], "[", "Y", "]"}], "[", "z", 
        "]"}]}], " ", "+", "\n", "   ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"z", "^", "2"}], " ", "-", " ", 
         RowBox[{"5", " ", "z"}]}], ")"}], " ", 
       RowBox[{
        RowBox[{
         RowBox[{"Derivative", "[", "2", "]"}], "[", "Y", "]"}], "[", "z", 
        "]"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", " ", "+", " ", "z"}], ")"}], " ", 
       RowBox[{
        RowBox[{
         RowBox[{"Derivative", "[", "1", "]"}], "[", "Y", "]"}], "[", "z", 
        "]"}]}], " ", "+", "\n", "   ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"lam", "^", "2"}], "/", "4"}], ")"}], " ", 
       RowBox[{"Y", "[", "z", "]"}]}]}]}], ";"}], "\n", "\n", 
   RowBox[{"zEquationCheck", " ", "=", " ", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{"odeInZ", " ", "-", " ", "targetZEquation"}], "]"}]}], 
   "\n"}]}]], "Input",
 CellLabel->"In[5]:=",ExpressionUUID->"14e1c8ba-ccb3-4097-8546-d8841a4a45b1"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   FractionBox["1", "4"], " ", 
   SuperscriptBox["lam", "2"], " ", 
   RowBox[{"Y", "[", "z", "]"}]}], "+", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"1", "+", "z"}], ")"}], " ", 
   RowBox[{
    SuperscriptBox["Y", "\[Prime]",
     MultilineFunction->None], "[", "z", "]"}]}], "+", 
  RowBox[{"z", " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "5"}], "+", "z"}], ")"}], " ", 
      RowBox[{
       SuperscriptBox["Y", "\[Prime]\[Prime]",
        MultilineFunction->None], "[", "z", "]"}]}], "-", 
     RowBox[{"2", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "2"}], "+", "z"}], ")"}], " ", 
      RowBox[{
       SuperscriptBox["Y", 
        TagBox[
         RowBox[{"(", "3", ")"}],
         Derivative],
        MultilineFunction->None], "[", "z", "]"}]}], "+", 
     RowBox[{"z", " ", 
      RowBox[{
       SuperscriptBox["Y", 
        TagBox[
         RowBox[{"(", "4", ")"}],
         Derivative],
        MultilineFunction->None], "[", "z", "]"}]}]}], ")"}]}]}]], "Output",
 CellChangeTimes->{3.9887043765177717`*^9},
 CellLabel->"Out[9]=",ExpressionUUID->"c3ef2bd7-6a3a-48aa-adc0-470de1744916"],

Cell[BoxData["0"], "Output",
 CellChangeTimes->{3.988704376518441*^9},
 CellLabel->"Out[11]=",ExpressionUUID->"e7f57f64-d87e-4b67-b6b6-a82268e947c4"]
}, Open  ]],

Cell["Expected: zEquationCheck = 0.", "Text",ExpressionUUID->"73050006-8f8b-4df9-b0f8-685602e9689a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["2. Kummer reduction", "Section",ExpressionUUID->"7c5ee067-247d-4ebc-900d-2efe9b093868"],

Cell["\<\
Let q = +/- I lam/2, so q^2 = -lam^2/4. Define Kummer's equation z w'' + \
(1-z) w' - q w = 0. If w solves it, then Y = (1+2q) w - 2 w' solves the \
fourth-order z-equation. This cell proves the statement algebraically by \
reducing all derivatives of w to w and w'.\
\>", "Text",ExpressionUUID->"7bdeb7a3-bf0a-4573-b90a-8fdf2a8dfa51"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\n", 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", "q", "]"}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"pair", "[", "n", "]"}], " ", "gives", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"coefficient", " ", "of", " ", "w"}], ",", " ", 
        RowBox[{"coefficient", " ", "of", " ", 
         RowBox[{"w", "'"}]}]}], "}"}], " ", "in", " ", 
      RowBox[{"d", "^", "n"}], " ", 
      RowBox[{"w", "/", 
       RowBox[{"dz", "^", "n"}]}]}], ",", "\n", "   ", 
     RowBox[{
      RowBox[{
       RowBox[{"assuming", " ", "z", " ", 
        RowBox[{"w", "''"}]}], " ", "+", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", "z"}], ")"}], " ", 
        RowBox[{"w", "'"}]}], " ", "-", " ", 
       RowBox[{"q", " ", "w"}]}], " ", "=", " ", "0."}]}], " ", "*)"}], "\n", 
   
   RowBox[{
    RowBox[{
     RowBox[{"pair", "[", "0", "]"}], " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{"1", ",", " ", "0"}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"pair", "[", "1", "]"}], " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{"0", ",", " ", "1"}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"nextPair", "[", 
      RowBox[{"{", 
       RowBox[{"cw_", ",", " ", "cv_"}], "}"}], "]"}], " ", ":=", " ", 
     RowBox[{"FullSimplify", "[", "\n", "   ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"D", "[", 
          RowBox[{"cw", ",", " ", "z"}], "]"}], " ", "+", " ", 
         RowBox[{"cv", " ", 
          RowBox[{"q", "/", "z"}]}]}], ",", " ", 
        RowBox[{"cw", " ", "+", " ", 
         RowBox[{"D", "[", 
          RowBox[{"cv", ",", " ", "z"}], "]"}], " ", "+", " ", 
         RowBox[{"cv", " ", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"z", " ", "-", " ", "1"}], ")"}], "/", "z"}]}]}]}], "}"}],
       "\n", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"pair", "[", "n", "]"}], " ", "=", " ", 
       RowBox[{"nextPair", "[", 
        RowBox[{"pair", "[", 
         RowBox[{"n", " ", "-", " ", "1"}], "]"}], "]"}]}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"n", ",", " ", "2", ",", " ", "5"}], "}"}]}], "]"}], ";"}], 
   "\n", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Ypair", "[", "n_", "]"}], " ", ":=", " ", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", " ", "+", " ", 
          RowBox[{"2", " ", "q"}]}], ")"}], " ", 
        RowBox[{"pair", "[", "n", "]"}]}], " ", "-", " ", 
       RowBox[{"2", " ", 
        RowBox[{"pair", "[", 
         RowBox[{"n", " ", "+", " ", "1"}], "]"}]}]}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"LzPair", " ", "=", "\n", "   ", 
     RowBox[{
      RowBox[{
       RowBox[{"z", "^", "2"}], " ", 
       RowBox[{"Ypair", "[", "4", "]"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"4", " ", "z"}], " ", "-", " ", 
         RowBox[{"2", " ", 
          RowBox[{"z", "^", "2"}]}]}], ")"}], " ", 
       RowBox[{"Ypair", "[", "3", "]"}]}], " ", "+", "\n", "   ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"z", "^", "2"}], " ", "-", " ", 
         RowBox[{"5", " ", "z"}]}], ")"}], " ", 
       RowBox[{"Ypair", "[", "2", "]"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", " ", "+", " ", "z"}], ")"}], " ", 
       RowBox[{"Ypair", "[", "1", "]"}]}], " ", "-", " ", 
      RowBox[{
       RowBox[{"q", "^", "2"}], " ", 
       RowBox[{"Ypair", "[", "0", "]"}]}]}]}], ";"}], "\n", "\n", 
   RowBox[{"kummerMapCheck", " ", "=", " ", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{"Together", "[", "LzPair", "]"}], "]"}]}], "\n"}]}]], "Input",
 CellLabel->"In[12]:=",ExpressionUUID->"e041617d-7520-45e2-a992-08a9d230f27f"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", "0"}], "}"}]], "Output",
 CellChangeTimes->{3.988704397672144*^9},
 CellLabel->"Out[19]=",ExpressionUUID->"94a9f757-f515-4bbe-b946-a439e82d01e2"]
}, Open  ]],

Cell["\<\
Expected: kummerMapCheck = {0,0}. This is the main structural result.\
\>", "Text",ExpressionUUID->"c7341c46-65ae-4e29-b4e9-0ad88cda59bc"]
}, Open  ]],

Cell[CellGroupData[{

Cell["3. General four-solution family", "Section",ExpressionUUID->"164d8331-2b29-4da6-afa3-827430e69b2f"],

Cell["\<\
For each q = +/- I lam/2, Kummer's equation has the two independent solutions \
M(q,1,z)=Hypergeometric1F1[q,1,z] and U(q,1,z)=HypergeometricU[q,1,z]. \
Applying Y=(1+2q)w-2w' gives four solutions of the fourth-order equation.\
\>", "Text",ExpressionUUID->"71996b6d-0ccc-4c50-97ca-b5d5e3e02ce0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"TfromKummer", "[", 
      RowBox[{"w_", ",", " ", "q_"}], "]"}], " ", ":=", " ", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", " ", "+", " ", 
          RowBox[{"2", " ", "q"}]}], ")"}], " ", "w"}], " ", "-", " ", 
       RowBox[{"2", " ", 
        RowBox[{"D", "[", 
         RowBox[{"w", ",", " ", "z"}], "]"}]}]}], "]"}]}], ";"}], "\n", "\n", 
   
   RowBox[{
    RowBox[{
     RowBox[{"YM", "[", "q_", "]"}], " ", ":=", " ", 
     RowBox[{
      RowBox[{"TfromKummer", "[", 
       RowBox[{
        RowBox[{"Hypergeometric1F1", "[", 
         RowBox[{"q", ",", " ", "1", ",", " ", "z"}], "]"}], ",", " ", "q"}], 
       "]"}], " ", "//", " ", "FunctionExpand"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"YU", "[", "q_", "]"}], " ", ":=", " ", 
     RowBox[{
      RowBox[{"TfromKummer", "[", 
       RowBox[{
        RowBox[{"HypergeometricU", "[", 
         RowBox[{"q", ",", " ", "1", ",", " ", "z"}], "]"}], ",", " ", "q"}], 
       "]"}], " ", "//", " ", "FunctionExpand"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"YM", "[", "q", "]"}], " ", "//", " ", "TraditionalForm"}], "\n", 
   
   RowBox[{
    RowBox[{"YU", "[", "q", "]"}], " ", "//", " ", "TraditionalForm"}], 
   "\n"}]}]], "Input",
 CellLabel->"In[20]:=",ExpressionUUID->"c9e3c602-266e-48da-9037-995c03f66115"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", "q"}], "+", "1"}], ")"}], " ", 
    TemplateBox[{
      RowBox[{"-", "q"}], "z"},
     "LaguerreL"]}], "-", 
   RowBox[{"2", " ", "q", " ", 
    TemplateBox[{
      RowBox[{"q", "+", "1"}], "2", "z"},
     "Hypergeometric1F1"]}]}], TraditionalForm]], "Output",
 CellChangeTimes->{3.988704408935891*^9},
 CellLabel->
  "Out[23]//TraditionalForm=",ExpressionUUID->"06c80b51-48cb-4df6-b4a5-\
708fbd258977"],

Cell[BoxData[
 FormBox[
  RowBox[{
   FractionBox[
    RowBox[{"2", " ", "q", " ", 
     TemplateBox[{"q", "0", "z"},
      "HypergeometricU"]}], "z"], "+", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", "q"}], "+", "1"}], ")"}], " ", 
    TemplateBox[{"q", "1", "z"},
     "HypergeometricU"]}]}], TraditionalForm]], "Output",
 CellChangeTimes->{3.988704408948483*^9},
 CellLabel->
  "Out[24]//TraditionalForm=",ExpressionUUID->"d46da47f-39fe-4d90-8518-\
953f180544e5"]
}, Open  ]],

Cell["\<\
Using derivative identities, these are equivalently YM=(1+2q) M(q,1,z)-2q \
M(q+1,2,z) and YU=(1+2q) U(q,1,z)+2q U(q+1,2,z).\
\>", "Text",ExpressionUUID->"2cd675a7-2064-4da4-b3fd-f416c39d0b17"]
}, Open  ]],

Cell[CellGroupData[{

Cell["4. The two known bounded solutions", "Section",ExpressionUUID->"fd5a101f-ccea-4dcb-b116-42b9dc41e50b"],

Cell["\<\
The already-known solutions are the two M-branch solutions, with q=-I lam/2 \
and q=+I lam/2, up to the normalization f0 used in the PDF.\
\>", "Text",ExpressionUUID->"668b14ec-1ba0-4a9e-aedf-125bba2f7963"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\n", 
  RowBox[{
   RowBox[{
    RowBox[{"zOfX", " ", "=", " ", 
     RowBox[{
      RowBox[{"-", "2"}], " ", "I", " ", "x"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"qMinus", " ", "=", " ", 
     RowBox[{
      RowBox[{"-", "I"}], " ", 
      RowBox[{"lam", "/", "2"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"qPlus", " ", "=", " ", 
     RowBox[{"I", " ", 
      RowBox[{"lam", "/", "2"}]}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"MminusX", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"YM", "[", "qMinus", "]"}], " ", "/.", " ", 
       RowBox[{"z", " ", "->", " ", "zOfX"}]}], " ", "//", " ", 
      "FunctionExpand"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"MplusX", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"YM", "[", "qPlus", "]"}], " ", "/.", " ", 
       RowBox[{"z", " ", "->", " ", "zOfX"}]}], " ", "//", " ", 
      "FunctionExpand"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"f0", "[", "mu_", "]"}], " ", ":=", " ", 
     RowBox[{
      RowBox[{"Gamma", "[", 
       RowBox[{"1", " ", "+", " ", 
        RowBox[{"I", " ", 
         RowBox[{"mu", "/", "2"}]}]}], "]"}], " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", " ", "-", " ", 
         RowBox[{"I", " ", "mu"}]}], ")"}], "^", 
       RowBox[{"(", 
        RowBox[{"-", "1"}], ")"}]}], " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"2", " ", "I"}], ")"}], "^", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "I"}], " ", 
         RowBox[{"mu", "/", "2"}]}], ")"}]}]}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"zeta11Known", " ", "=", "\n", "   ", 
     RowBox[{
      RowBox[{"f0", "[", "lam", "]"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", " ", "-", " ", 
           RowBox[{"I", " ", "lam"}]}], ")"}], " ", 
         RowBox[{"LaguerreL", "[", 
          RowBox[{
           RowBox[{"I", " ", 
            RowBox[{"lam", "/", "2"}]}], ",", " ", 
           RowBox[{
            RowBox[{"-", "2"}], " ", "I", " ", "x"}]}], "]"}]}], " ", "+", 
        "\n", "      ", 
        RowBox[{"I", " ", "lam", " ", 
         RowBox[{"Hypergeometric1F1", "[", 
          RowBox[{
           RowBox[{"1", " ", "-", " ", 
            RowBox[{"I", " ", 
             RowBox[{"lam", "/", "2"}]}]}], ",", " ", "2", ",", " ", 
           RowBox[{
            RowBox[{"-", "2"}], " ", "I", " ", "x"}]}], "]"}]}]}], ")"}]}]}], 
    ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"zeta12Known", " ", "=", "\n", "   ", 
     RowBox[{
      RowBox[{"f0", "[", 
       RowBox[{"-", "lam"}], "]"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", " ", "+", " ", 
           RowBox[{"I", " ", "lam"}]}], ")"}], " ", 
         RowBox[{"LaguerreL", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"-", "I"}], " ", 
            RowBox[{"lam", "/", "2"}]}], ",", " ", 
           RowBox[{
            RowBox[{"-", "2"}], " ", "I", " ", "x"}]}], "]"}]}], " ", "-", 
        "\n", "      ", 
        RowBox[{"I", " ", "lam", " ", 
         RowBox[{"Hypergeometric1F1", "[", 
          RowBox[{
           RowBox[{"1", " ", "+", " ", 
            RowBox[{"I", " ", 
             RowBox[{"lam", "/", "2"}]}]}], ",", " ", "2", ",", " ", 
           RowBox[{
            RowBox[{"-", "2"}], " ", "I", " ", "x"}]}], "]"}]}]}], ")"}]}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"knownCheck11", " ", "=", " ", 
    RowBox[{"safeSimplify", "[", 
     RowBox[{
      RowBox[{"zeta11Known", "/", 
       RowBox[{"f0", "[", "lam", "]"}]}], " ", "-", " ", "MminusX"}], "]"}]}],
    "\n", 
   RowBox[{"knownCheck12", " ", "=", " ", 
    RowBox[{"safeSimplify", "[", 
     RowBox[{
      RowBox[{"zeta12Known", "/", 
       RowBox[{"f0", "[", 
        RowBox[{"-", "lam"}], "]"}]}], " ", "-", " ", "MplusX"}], "]"}]}], 
   "\n"}]}]], "Input",
 CellLabel->"In[25]:=",ExpressionUUID->"1a2850e3-1901-49f7-b3c1-14da979999ad"],

