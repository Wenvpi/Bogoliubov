Cell[CellGroupData[{

Cell["8. Behavior near x = 0", "Section",ExpressionUUID->"78656011-10bd-4549-964c-08d856415cd6"],

Cell["\<\
The U-branch solutions are singular at x=0 because HypergeometricU[q+1,2,z] \
has a 1/z leading term. This is why they were missed by the bounded \
Laplace-transform construction.\
\>", "Text",ExpressionUUID->"537eaab7-8c8d-4eee-a320-8c3f52d89640"],

Cell[BoxData[
 RowBox[{"\n", 
  RowBox[{
   RowBox[{
    RowBox[{"Series", "[", 
     RowBox[{"zeta13Candidate", ",", " ", 
      RowBox[{"{", 
       RowBox[{"x", ",", " ", "0", ",", " ", "1"}], "}"}]}], "]"}], " ", "//",
     " ", "FunctionExpand"}], "\n", 
   RowBox[{
    RowBox[{"Series", "[", 
     RowBox[{"zeta14Candidate", ",", " ", 
      RowBox[{"{", 
       RowBox[{"x", ",", " ", "0", ",", " ", "1"}], "}"}]}], "]"}], " ", "//",
     " ", "FunctionExpand"}], "\n"}]}]], "Input",ExpressionUUID->"fe182c03-\
da86-4b10-bc6e-9b457fd25b50"],

Cell["\<\
If Mathematica does not print a compact series for symbolic lam, try \
numerical lam values:\
\>", "Text",ExpressionUUID->"5dec9a73-c389-4f6f-9cf2-423f63a2714a"],

Cell[BoxData[
 RowBox[{"\n", 
  RowBox[{
   RowBox[{"Series", "[", 
    RowBox[{
     RowBox[{"zeta13Candidate", " ", "/.", " ", 
      RowBox[{"lam", " ", "->", " ", 
       RowBox[{"59", "/", "50"}]}]}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", "0", ",", " ", "2"}], "}"}]}], "]"}], "\n", 
   RowBox[{"Series", "[", 
