       RowBox[{"59", "/", "50"}]}]}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", "0", ",", " ", "2"}], "}"}]}], "]"}], 
   "\n"}]}]], "Input",ExpressionUUID->"ba5c7785-f085-40e7-88f4-1a952f91f521"]
}, Open  ]],

Cell[CellGroupData[{

Cell["9. Behavior at large x", "Section",ExpressionUUID->"7ce02a66-774c-486a-ba5e-e3e47d8f9ce3"],

Cell["\<\
HypergeometricU[q,1,z] behaves like z^(-q) at infinity, while \
HypergeometricU[q+1,2,z] is one power lower. Thus the U-branch has the same \
leading algebraic power as the matching q-branch, but it is independent and \
singular at x=0. Other asymptotic bases can be formed by taking linear \
combinations with the M-branch solutions.\
\>", "Text",ExpressionUUID->"1c90ed38-5e62-489f-aa23-553a209f04fd"],

Cell[BoxData[
 RowBox[{"\n", 
  RowBox[{
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"N", "[", 
      RowBox[{
       RowBox[{"zeta13Candidate", " ", "/.", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"lam", " ", "->", " ", 
           RowBox[{"59", "/", "50"}]}], ",", " ", 
          RowBox[{"x", " ", "->", " ", "X"}]}], "}"}]}], ",", " ", "30"}], 
      "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"X", ",", " ", 
       RowBox[{"{", 
        RowBox[{"50", ",", " ", "100", ",", " ", "200", ",", " ", "500"}], 
        "}"}]}], "}"}]}], "]"}], "\n", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"N", "[", 
      RowBox[{
       RowBox[{"zeta14Candidate", " ", "/.", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"lam", " ", "->", " ", 
           RowBox[{"59", "/", "50"}]}], ",", " ", 
          RowBox[{"x", " ", "->", " ", "X"}]}], "}"}]}], ",", " ", "30"}], 
      "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"X", ",", " ", 
       RowBox[{"{", 
        RowBox[{"50", ",", " ", "100", ",", " ", "200", ",", " ", "500"}], 
        "}"}]}], "}"}]}], "]"}], "\n"}]}]], "Input",ExpressionUUID->"e87f1f6a-\
ca68-40b9-825e-86e17ef2d117"]
}, Open  ]],

Cell[CellGroupData[{

Cell["10. Optional Jost-type subleading basis at infinity", "Section",ExpressionUUID->"0a227dbe-7ca6-4afa-b3ba-22772d0eb2f7"],

Cell["\<\
The M-branch has a leading algebraic term proportional to z^(-q) plus an e^z \
z^(q-1) term. The U-branch has only the leading algebraic term z^(-q). \
Therefore YM[q] - Exp[I Pi q]/Gamma[1-q] YU[q] cancels the algebraic leading \
term and isolates the e^z z^(q-1) branch, up to branch conventions. This is \
often the basis one wants for the x^(-1 +/- i lam/2) large-x modes.\
\>", "Text",ExpressionUUID->"4ac451b5-7f95-4770-8ab0-2073b9f53ee8"],

Cell[BoxData[
 RowBox[{"\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"YExp", "[", "q_", "]"}], " ", ":=", " ", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{
       RowBox[{"YM", "[", "q", "]"}], " ", "-", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"Exp", "[", 
          RowBox[{"I", " ", "Pi", " ", "q"}], "]"}], "/", 
         RowBox[{"Gamma", "[", 
          RowBox[{"1", " ", "-", " ", "q"}], "]"}]}], " ", 
        RowBox[{"YU", "[", "q", "]"}]}]}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"zetaExpMinus", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"YExp", "[", "qMinus", "]"}], " ", "/.", " ", 
       RowBox[{"z", " ", "->", " ", "zOfX"}]}], " ", "//", " ", 
      "FunctionExpand"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"zetaExpPlus", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"YExp", "[", "qPlus", "]"}], " ", "/.", " ", 
       RowBox[{"z", " ", "->", " ", "zOfX"}]}], " ", "//", " ", 
      "FunctionExpand"}]}], ";"}], "\n", "\n", 
   RowBox[{"expResidualMinus", " ", "=", " ", 
    RowBox[{"safeSimplify", "[", 
     RowBox[{
      RowBox[{"odeX", "[", "zetaExpMinus", "]"}], ",", " ", "90"}], "]"}]}], "\n", 
   RowBox[{"expResidualPlus", " ", "=", " ", 
    RowBox[{"safeSimplify", "[", 
     RowBox[{
      RowBox[{"odeX", "[", "zetaExpPlus", "]"}], ",", " ", "90"}], "]"}]}], 
   "\n", "\n", 
   RowBox[{"Chop", "[", 
    RowBox[{
     RowBox[{"numericResiduals", "[", 
      RowBox[{
       RowBox[{"odeX", "[", "zetaExpMinus", "]"}], ",", " ", 
       RowBox[{"59", "/", "50"}]}], "]"}], ",", " ", 
     RowBox[{"10", "^", 
      RowBox[{"-", "35"}]}]}], "]"}], "\n", 
   RowBox[{"Chop", "[", 
    RowBox[{
     RowBox[{"numericResiduals", "[", 
      RowBox[{
       RowBox[{"odeX", "[", "zetaExpPlus", "]"}], ",", " ", 
       RowBox[{"59", "/", "50"}]}], "]"}], ",", " ", 
     RowBox[{"10", "^", 
      RowBox[{"-", "35"}]}]}], "]"}], "\n"}]}]], "Input",ExpressionUUID->\
"201d6373-4a9b-4942-9b21-4fbced9bc6d8"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Conclusion", "Section",ExpressionUUID->"1c3e1733-ef59-45d1-a955-c5f6a4da3336"],

Cell["\<\
Concrete result: the two missing solutions can be taken as zeta13Candidate \
and zeta14Candidate above. They come from the HypergeometricU branch of the \
same Kummer equation that generates the known Hypergeometric1F1/Laguerre \
branch. If the desired basis is the subleading large-x/Jost basis, use \
zetaExpMinus and zetaExpPlus instead. The most important check is \
kummerMapCheck={0,0}; it proves the construction before any special-function \
simplification is attempted.\
\>", "Text",ExpressionUUID->"80aa670c-ddcb-41a2-9352-784fe1c0ba9a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Solve", "[", 
  RowBox[{
   RowBox[{"a", "==", 
    RowBox[{
     RowBox[{"-", "2"}], "*", "I", "*", "b"}]}], ",", "b"}], "]"}]], "Input",
 CellChangeTimes->{{3.988706305541521*^9, 3.988706377655854*^9}},
 CellLabel->"In[55]:=",ExpressionUUID->"3407fd81-5ef0-47c8-acde-47b388945014"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{"b", "\[Rule]", 
    FractionBox[
