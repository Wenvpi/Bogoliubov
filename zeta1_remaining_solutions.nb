Cell[CellGroupData[{

Cell["7. Linear independence check", "Section",ExpressionUUID->"12e53e57-cedd-4b53-a77f-6a7f04467672"],

Cell["\<\
This computes a numerical Wronskian for the four solutions at one regular \
point. A nonzero result confirms that the two U-branch functions add the \
missing dimensions.\
\>", "Text",ExpressionUUID->"8527765d-de91-45f1-96e6-99824ea4793c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\n", 
  RowBox[{
   RowBox[{
    RowBox[{"fourSolutions", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
      "MminusX", ",", " ", "MplusX", ",", " ", "zeta13Candidate", ",", " ", 
       "zeta14Candidate"}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"wronskian", " ", "=", " ", 
     RowBox[{"Det", "[", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"fourSolutions", "[", 
           RowBox[{"[", "j", "]"}], "]"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"x", ",", " ", "k"}], "}"}]}], "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"k", ",", " ", "0", ",", " ", "3"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"j", ",", " ", "1", ",", " ", "4"}], "}"}]}], "]"}], "]"}]}],
     ";"}], "\n", "\n", 
   RowBox[{"N", "[", 
    RowBox[{
     RowBox[{"wronskian", " ", "/.", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"lam", " ", "->", " ", 
         RowBox[{"59", "/", "50"}]}], ",", " ", 
        RowBox[{"x", " ", "->", " ", 
         RowBox[{"13", "/", "10"}]}]}], "}"}]}], ",", " ", "40"}], "]"}], 
   "\n"}]}]], "Input",
 CellLabel->"In[45]:=",ExpressionUUID->"463725c5-7be2-4a7c-9e51-6742899797d8"],

