Cell[CellGroupData[{

Cell["5. Proposed missing pair", "Section",ExpressionUUID->"23598e35-c5c7-42df-b3a9-30a1ad58f43e"],

Cell["\<\
The missing pair is obtained by applying the same map to HypergeometricU.\
\>", "Text",ExpressionUUID->"2e201bb3-9c99-4d3e-ae28-723a9e784801"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\n", 
  RowBox[{
   RowBox[{
    RowBox[{"zeta13Candidate", " ", "=", "\n", "   ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", " ", "-", " ", 
          RowBox[{"I", " ", "lam"}]}], ")"}], " ", 
        RowBox[{"HypergeometricU", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"-", "I"}], " ", 
           RowBox[{"lam", "/", "2"}]}], ",", " ", "1", ",", " ", 
          RowBox[{
           RowBox[{"-", "2"}], " ", "I", " ", "x"}]}], "]"}]}], " ", "-", 
       "\n", "      ", 
       RowBox[{"I", " ", "lam", " ", 
        RowBox[{"HypergeometricU", "[", 
         RowBox[{
          RowBox[{"1", " ", "-", " ", 
           RowBox[{"I", " ", 
            RowBox[{"lam", "/", "2"}]}]}], ",", " ", "2", ",", " ", 
          RowBox[{
           RowBox[{"-", "2"}], " ", "I", " ", "x"}]}], "]"}]}]}], ")"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"zeta14Candidate", " ", "=", "\n", "   ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", " ", "+", " ", 
          RowBox[{"I", " ", "lam"}]}], ")"}], " ", 
        RowBox[{"HypergeometricU", "[", 
         RowBox[{
          RowBox[{"I", " ", 
           RowBox[{"lam", "/", "2"}]}], ",", " ", "1", ",", " ", 
          RowBox[{
           RowBox[{"-", "2"}], " ", "I", " ", "x"}]}], "]"}]}], " ", "+", 
       "\n", "      ", 
       RowBox[{"I", " ", "lam", " ", 
        RowBox[{"HypergeometricU", "[", 
         RowBox[{
          RowBox[{"1", " ", "+", " ", 
           RowBox[{"I", " ", 
            RowBox[{"lam", "/", "2"}]}]}], ",", " ", "2", ",", " ", 
          RowBox[{
           RowBox[{"-", "2"}], " ", "I", " ", "x"}]}], "]"}]}]}], ")"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"zeta13Candidate", ",", " ", "zeta14Candidate"}], "}"}], " ", "//",
     " ", "TraditionalForm"}], "\n"}]}]], "Input",
 CellLabel->"In[35]:=",ExpressionUUID->"afc74371-2609-4a79-8c9f-965f66a5408d"],

Cell[BoxData[
 FormBox[
  RowBox[{"{", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{"\[ImaginaryI]", " ", "lam"}]}], ")"}], " ", 
      TemplateBox[{
        RowBox[{"-", 
          FractionBox[
           RowBox[{"\[ImaginaryI]", " ", "lam"}], "2"]}], "1", 
        RowBox[{
          RowBox[{"-", "2"}], " ", "\[ImaginaryI]", " ", "x"}]},
       "HypergeometricU"]}], "-", 
     RowBox[{"\[ImaginaryI]", " ", "lam", " ", 
      TemplateBox[{
        RowBox[{"1", "-", 
          FractionBox[
           RowBox[{"\[ImaginaryI]", " ", "lam"}], "2"]}], "2", 
        RowBox[{
          RowBox[{"-", "2"}], " ", "\[ImaginaryI]", " ", "x"}]},
       "HypergeometricU"]}]}], ",", 
    RowBox[{
     RowBox[{"\[ImaginaryI]", " ", "lam", " ", 
      TemplateBox[{
        RowBox[{
          FractionBox[
           RowBox[{"\[ImaginaryI]", " ", "lam"}], "2"], "+", "1"}], "2", 
        RowBox[{
          RowBox[{"-", "2"}], " ", "\[ImaginaryI]", " ", "x"}]},
       "HypergeometricU"]}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "+", 
        RowBox[{"\[ImaginaryI]", " ", "lam"}]}], ")"}], " ", 
      TemplateBox[{
        FractionBox[
         RowBox[{"\[ImaginaryI]", " ", "lam"}], "2"], "1", 
        RowBox[{
          RowBox[{"-", "2"}], " ", "\[ImaginaryI]", " ", "x"}]},
       "HypergeometricU"]}]}]}], "}"}], TraditionalForm]], "Output",
 CellChangeTimes->{3.9887044501183453`*^9},
 CellLabel->
  "Out[37]//TraditionalForm=",ExpressionUUID->"9bdc5754-c448-45c5-951b-\
973f96968b3d"]
}, Open  ]],

Cell["\<\
These are unnormalized. Multiplying either by any nonzero constant, or adding \
any linear combination of zeta11 and zeta12, gives an equivalent missing \
basis.\
\>", "Text",ExpressionUUID->"069a941c-6450-443e-8be8-a05ba42572de"]
}, Open  ]],

Cell[CellGroupData[{

Cell["6. Direct verification in the original x-equation", "Section",ExpressionUUID->"f2c6f8f9-3cbe-4faa-99d0-7ca2773ff3df"],

Cell["\<\
The symbolic checks may be hard for Mathematica, so numerical residuals are \
included. The structural proof above is stronger than a direct simplification \
failure.\
\>", "Text",ExpressionUUID->"05e98c3f-9404-4b82-8c3e-39795d104fe9"],

